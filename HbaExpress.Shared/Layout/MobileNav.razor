@inject AuthState Auth
@inject NavigationManager Nav

@* ============================================================
   Navigation mobile type application native : barre d'onglets
   fixée en bas (5 accès principaux) + feuille « Plus » pour le
   reste. Visible uniquement sous 641px (cf. MobileNav.razor.css).
   ============================================================ *@

<nav class="mnav" aria-label="Navigation principale">
    <NavLink class="mnav-item" href="" Match="NavLinkMatch.All">
        <span class="mnav-ico" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="9" rx="1"/><rect x="14" y="3" width="7" height="5" rx="1"/><rect x="14" y="12" width="7" height="9" rx="1"/><rect x="3" y="16" width="7" height="5" rx="1"/></svg>
        </span>
        <span class="mnav-txt">Accueil</span>
    </NavLink>
    <NavLink class="mnav-item" href="commandes">
        <span class="mnav-ico" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="8" y="2" width="8" height="4" rx="1"/><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><path d="M9 12h6M9 16h6"/></svg>
        </span>
        <span class="mnav-txt">Commandes</span>
    </NavLink>
    <NavLink class="mnav-item" href="produits">
        <span class="mnav-ico" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></svg>
        </span>
        <span class="mnav-txt">Produits</span>
    </NavLink>
    <NavLink class="mnav-item" href="finances">
        <span class="mnav-ico" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="M18 17V9"/><path d="M13 17V5"/><path d="M8 17v-3"/></svg>
        </span>
        <span class="mnav-txt">Finances</span>
    </NavLink>
    <button type="button" class="mnav-item mnav-more @(_sheetOpen ? "is-open" : null)" @onclick="OpenSheet" aria-haspopup="true" aria-expanded="@_sheetOpen">
        <span class="mnav-ico" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="5" cy="12" r="1.6"/><circle cx="12" cy="12" r="1.6"/><circle cx="19" cy="12" r="1.6"/></svg>
        </span>
        <span class="mnav-txt">Plus</span>
    </button>
</nav>

@if (_sheetOpen)
{
    <div class="msheet-backdrop" @onclick="CloseSheet"></div>
    <div class="msheet" role="dialog" aria-label="Plus d'options">
        <div class="msheet-grip" aria-hidden="true"></div>
        <div class="msheet-grid">
            <a class="msheet-link" href="apercu-catalogue" @onclick="CloseSheet">
                <span class="msheet-ico" aria-hidden="true"><svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/></svg></span>
                <span>Aperçu catalogue</span>
            </a>
            <a class="msheet-link" href="portefeuille" @onclick="CloseSheet">
                <span class="msheet-ico" aria-hidden="true"><svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M19 7V5a2 2 0 0 0-2-2H5a2 2 0 0 0 0 4h16a1 1 0 0 1 1 1v3"/><path d="M3 5v14a2 2 0 0 0 2 2h15a1 1 0 0 0 1-1v-3"/><path d="M18 12a2 2 0 0 0 0 4h4v-4Z"/></svg></span>
                <span>Portefeuille</span>
            </a>
            <a class="msheet-link" href="notifications" @onclick="CloseSheet">
                <span class="msheet-ico" aria-hidden="true"><svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.7 21a2 2 0 0 1-3.4 0"/></svg></span>
                <span>Notifications</span>
            </a>
            <a class="msheet-link" href="messagerie" @onclick="CloseSheet">
                <span class="msheet-ico" aria-hidden="true"><svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/></svg></span>
                <span>Messagerie</span>
            </a>
            <a class="msheet-link" href="avis" @onclick="CloseSheet">
                <span class="msheet-ico" aria-hidden="true"><svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.1 8.3 22 9.3 17 14.1 18.2 21 12 17.8 5.8 21 7 14.1 2 9.3 8.9 8.3 12 2"/></svg></span>
                <span>Avis</span>
            </a>
            <a class="msheet-link" href="expeditions" @onclick="CloseSheet">
                <span class="msheet-ico" aria-hidden="true"><svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 18V6a1 1 0 0 0-1-1H3a1 1 0 0 0-1 1v11a1 1 0 0 0 1 1h1"/><path d="M14 9h4l4 4v4a1 1 0 0 1-1 1h-1"/><circle cx="7" cy="18" r="2"/><circle cx="17" cy="18" r="2"/><path d="M9 18h6"/></svg></span>
                <span>Expéditions</span>
            </a>
            <a class="msheet-link" href="boutique" @onclick="CloseSheet">
                <span class="msheet-ico" aria-hidden="true"><svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="m2 7 2-4h16l2 4"/><path d="M4 7v13a1 1 0 0 0 1 1h14a1 1 0 0 0 1-1V7"/><path d="M2 7h20"/><path d="M9 21v-6h6v6"/></svg></span>
                <span>Ma boutique</span>
            </a>
            <a class="msheet-link" href="profil" @onclick="CloseSheet">
                <span class="msheet-ico" aria-hidden="true"><svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21a8 8 0 0 0-16 0"/><circle cx="12" cy="7" r="4"/></svg></span>
                <span>Mon profil</span>
            </a>
        </div>
        <button type="button" class="msheet-logout" @onclick="Logout">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
            Se déconnecter
        </button>
    </div>
}

@code {
    private bool _sheetOpen;

    private void OpenSheet() => _sheetOpen = true;
    private void CloseSheet() => _sheetOpen = false;

    private async Task Logout()
    {
        _sheetOpen = false;
        await Auth.ClearAsync();
        Nav.NavigateTo("login");
    }
}
