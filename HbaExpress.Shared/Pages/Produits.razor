@page "/produits"

<PageTitle>Produits — Espace Vendeur</PageTitle>

<PageHeader Title="Produits"
            Subtitle="@($"{(_products?.Count ?? 0)} références dans votre catalogue")">
    <Actions>
        <MpButton Variant="ButtonVariant.Primary" Icon="plus" OnClick="@(() => _showCreate = true)">Ajouter un produit</MpButton>
    </Actions>
</PageHeader>

<MpModal @bind-Visible="_showCreate" Title="Nouveau produit">
    <ChildContent>
        <div class="mp-form">
            <div class="mp-field">
                <label>Nom du produit</label>
                <input class="mp-input" @bind="_form.Name" placeholder="Ex. Casque audio sans fil" />
            </div>
            <div class="mp-field">
                <label>Catégorie</label>
                @if (_categories is null)
                {
                    <p class="mp-caption">Chargement des catégories…</p>
                }
                else if (_categories.Count == 0)
                {
                    <p class="form-error">Aucune catégorie disponible. Un administrateur doit en créer.</p>
                }
                else
                {
                    <select class="mp-select" @bind="_form.CategoryId">
                        <option value="">— Choisir une catégorie —</option>
                        @foreach (var cat in _categories)
                        {
                            <option value="@cat.Id">@cat.Display</option>
                        }
                    </select>
                }
            </div>
            <div class="mp-field">
                <label>Description</label>
                <textarea class="mp-textarea" rows="2" @bind="_form.Description" placeholder="Description du produit"></textarea>
            </div>

            <div class="mp-field">
                <label>Marque <span class="mp-caption">(optionnel)</span></label>
                <select class="mp-select" @bind="_form.BrandId">
                    <option value="">— Aucune marque —</option>
                    @if (_brands is not null)
                    {
                        @foreach (var b in _brands)
                        {
                            <option value="@b.Id">@b.Name</option>
                        }
                    }
                </select>
            </div>

            <div class="mp-grid-2">
                <div class="mp-field">
                    <label>GTIN <span class="mp-caption">(optionnel)</span></label>
                    <input class="mp-input" @bind="_form.Gtin" placeholder="Ex. 0123456789012" />
                </div>
                <div class="mp-field">
                    <label>EAN <span class="mp-caption">(optionnel)</span></label>
                    <input class="mp-input" @bind="_form.Ean" placeholder="Ex. 3401597803487" />
                </div>
            </div>

            <div class="mp-field">
                <label>Groupe de produit <span class="mp-caption">(optionnel · GUID de déclinaison)</span></label>
                <input class="mp-input" @bind="_productGroupIdText" placeholder="Laisser vide si non applicable" />
            </div>

            <div class="mp-field">
                <label>Tags <span class="mp-caption">(séparés par des virgules)</span></label>
                <input class="mp-input" @bind="_tagsText" placeholder="Ex. promo, été, nouveauté" />
            </div>

            <div class="mp-field">
                <label>Attributs <span class="mp-caption">(clé / valeur)</span></label>
                @foreach (var attr in _form.Attributes)
                {
                    <div class="attr-row">
                        <input class="mp-input" placeholder="Couleur" @bind="attr.Key" />
                        <input class="mp-input" placeholder="Noir" @bind="attr.Value" />
                        <button type="button" class="attr-x" title="Retirer" @onclick="@(() => _form.Attributes.Remove(attr))"><AppIcon Name="x" Size="14" /></button>
                    </div>
                }
                <button type="button" class="attr-add" @onclick="@(() => _form.Attributes.Add(new ProductAttribute()))"><AppIcon Name="plus" Size="14" /> Ajouter un attribut</button>
            </div>

            <div class="mp-field">
                <label>Images <span class="mp-caption">(détourage auto sur fond blanc · la 1re est l'image principale)</span></label>
                <InputFile OnChange="OnFilesSelected" multiple accept="image/*" />
                @if (_drafts.Count > 0)
                {
                    <div class="img-drafts">
                        @for (var i = 0; i < _drafts.Count; i++)
                        {
                            var idx = i;
                            var d = _drafts[idx];
                            <div class="img-draft @(idx == 0 ? "is-primary" : null)">
                                <div class="img-draft-head">
                                    <span class="img-draft-title">
                                        @if (idx == 0)
                                        {
                                            <span class="img-primary-tag">★ Principale</span>
                                        }
                                        else
                                        {
                                            <text>Image @(idx + 1)</text>
                                        }
                                    </span>
                                    <button type="button" class="img-draft-x" title="Retirer" @onclick="@(() => RemoveImage(idx))"><AppIcon Name="x" Size="14" /></button>
                                </div>

                                <div class="img-compare">
                                    <figure class="img-side @(!d.UseProcessed ? "is-chosen" : null)">
                                        <img src="@d.Original.DataUrl" alt="Avant" />
                                        <figcaption>Avant</figcaption>
                                    </figure>
                                    <div class="img-arrow" aria-hidden="true">→</div>
                                    <figure class="img-side @(d.UseProcessed && d.Processed is not null ? "is-chosen" : null)">
                                        @if (d.IsProcessing)
                                        {
                                            <div class="img-state"><span class="img-spinner"></span><span>Détourage…</span></div>
                                        }
                                        else if (d.Processed is not null)
                                        {
                                            <img class="img-white" src="@d.Processed.DataUrl" alt="Après" />
                                        }
                                        else
                                        {
                                            <div class="img-state img-state-err">
                                                <span>Indisponible</span>
                                                <button type="button" class="img-retry" @onclick="@(() => RetryProcess(d))">Réessayer</button>
                                            </div>
                                        }
                                        <figcaption>Après · fond blanc</figcaption>
                                    </figure>
                                </div>

                                @if (d.Processed is not null)
                                {
                                    <div class="img-choice" role="group" aria-label="Version à conserver">
                                        <button type="button" class="img-choice-btn @(d.UseProcessed ? "active" : null)" @onclick="@(() => UseVersion(d, true))">Fond blanc</button>
                                        <button type="button" class="img-choice-btn @(!d.UseProcessed ? "active" : null)" @onclick="@(() => UseVersion(d, false))">Originale</button>
                                    </div>
                                }

                                @if (idx != 0)
                                {
                                    <button type="button" class="img-setprimary" @onclick="@(() => SetPrimary(idx))">Définir comme principale</button>
                                }
                            </div>
                        }
                    </div>
                }
            </div>

            @if (_formError is not null)
            {
                <p class="form-error">@_formError</p>
            }
        </div>
    </ChildContent>
    <Footer>
        <MpButton Variant="ButtonVariant.Secondary" OnClick="@(() => _showCreate = false)">Annuler</MpButton>
        <MpButton Variant="ButtonVariant.Primary" OnClick="CreateProduct">Créer le produit</MpButton>
    </Footer>
</MpModal>

@* --- Confirmation de suppression --- *@
<MpModal Visible="_deleteTarget is not null" VisibleChanged="@((bool v) => { if (!v) _deleteTarget = null; })" Title="">
    <ChildContent>
        <div class="del-confirm">
            <div class="del-ico"><AppIcon Name="trash" Size="28" /></div>
            <h3 class="del-title">Supprimer le produit ?</h3>
            <p class="del-text">
                Cette action est irréversible. Le produit
                <strong>« @(_deleteTarget?.Name) »</strong> sera définitivement retiré du marché.
            </p>
            @if (_deleteError is not null) { <p class="form-error">@_deleteError</p> }
        </div>
    </ChildContent>
    <Footer>
        <MpButton Variant="ButtonVariant.Secondary" Disabled="@_deleting" OnClick="@(() => _deleteTarget = null)">Garder</MpButton>
        <MpButton Variant="ButtonVariant.Danger" Disabled="@_deleting" OnClick="ConfirmDelete">
            @(_deleting ? "Suppression…" : "Oui, supprimer")
        </MpButton>
    </Footer>
</MpModal>

<style>
    /* Produits en cartes verticales, disposées en grille (style « À la une » client). */
    .prod-cards { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: var(--mp-space-3); align-items: stretch; }
    .prod-card { position: relative; display: flex; flex-direction: column; background: var(--mp-surface); border: 1px solid var(--mp-border); border-radius: var(--mp-radius-lg); box-shadow: var(--mp-shadow-sm); overflow: hidden; }
    .prod-thumb { display: flex; align-items: center; justify-content: center; width: 100%; aspect-ratio: 1 / 1; background: var(--mp-surface-2); font-size: 44px; overflow: hidden; }
    .prod-thumb img { width: 100%; height: 100%; object-fit: cover; }
    .prod-body { display: flex; flex-direction: column; gap: 6px; padding: var(--mp-space-3); flex: 1; }
    .prod-name { font-size: 14px; font-weight: 600; color: var(--mp-text); line-height: 1.3; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .prod-name:hover { color: var(--mp-primary); text-decoration: none; }
    .prod-price { font-family: var(--mp-font-display); font-size: 16px; font-weight: 700; color: var(--mp-primary-dark); white-space: nowrap; }
    .prod-body :is(.mp-badge, [class*="badge"]) { align-self: flex-start; }
    /* Bouton supprimer en pastille flottante, coin haut-droit de l'image. */
    .prod-del { position: absolute; top: 8px; right: 8px; z-index: 1; border: none; background: rgba(255, 255, 255, 0.92); color: var(--mp-danger); cursor: pointer; width: 34px; height: 34px; border-radius: 999px; display: inline-flex; align-items: center; justify-content: center; box-shadow: var(--mp-shadow-sm); }
    .prod-del:hover { background: var(--mp-badge-rupture-bg); color: var(--mp-danger); }

    .del-confirm { text-align: center; display: flex; flex-direction: column; align-items: center; gap: var(--mp-space-3); padding: var(--mp-space-2) var(--mp-space-2) 0; }
    .del-ico { width: 64px; height: 64px; border-radius: 50%; background-color: var(--mp-badge-rupture-bg); color: var(--mp-danger); display: flex; align-items: center; justify-content: center; font-size: 28px; }
    .del-title { font-size: 20px; font-weight: 800; margin: 0; color: var(--mp-text); }
    .del-text { color: var(--mp-text-muted); line-height: 1.5; margin: 0; max-width: 360px; }
    .mp-grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: var(--mp-space-3); }
    .attr-row { display: grid; grid-template-columns: 1fr 1fr auto; gap: var(--mp-space-2); margin-bottom: var(--mp-space-2); align-items: center; }
    .attr-x { border: none; background: none; cursor: pointer; color: var(--mp-text-muted, #888); font-size: .85rem; display: inline-flex; align-items: center; justify-content: center; }
    .attr-add { border: 1px dashed var(--mp-border); background: none; cursor: pointer; padding: var(--mp-space-2); border-radius: 6px; font-size: .85rem; color: var(--mp-primary, #1d4ed8); display: inline-flex; align-items: center; gap: 6px; }

    /* --- Récap image avant/après (détourage Cloudinary) --- */
    .img-drafts { display: flex; flex-direction: column; gap: var(--mp-space-3); margin-top: var(--mp-space-3); }
    .img-draft { border: 1px solid var(--mp-border); border-radius: var(--mp-radius-lg); padding: var(--mp-space-3); background: var(--mp-surface); }
    .img-draft.is-primary { border-color: var(--mp-primary); box-shadow: 0 0 0 1px var(--mp-primary) inset; }
    .img-draft-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: var(--mp-space-2); }
    .img-draft-title { font-size: 13px; font-weight: 600; color: var(--mp-text-muted); }
    .img-primary-tag { color: var(--mp-primary-dark); }
    .img-draft-x { border: none; background: transparent; color: var(--mp-text-muted); cursor: pointer; width: 28px; height: 28px; border-radius: var(--mp-radius-md); display: inline-flex; align-items: center; justify-content: center; }
    .img-draft-x:hover { background: var(--mp-badge-rupture-bg); color: var(--mp-danger); }

    .img-compare { display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; gap: var(--mp-space-2); }
    .img-side { margin: 0; display: flex; flex-direction: column; gap: 4px; }
    .img-side img, .img-side .img-state { width: 100%; aspect-ratio: 1 / 1; object-fit: cover; border-radius: var(--mp-radius-md); border: 1px solid var(--mp-border); }
    .img-side .img-white { background: #fff; object-fit: contain; }
    .img-side figcaption { font-size: 11px; text-align: center; color: var(--mp-text-muted); }
    .img-side.is-chosen img, .img-side.is-chosen .img-state { border: 2px solid var(--mp-primary); }
    .img-arrow { color: var(--mp-text-muted); font-size: 18px; }

    .img-state { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 6px; background: var(--mp-surface-2); font-size: 12px; color: var(--mp-text-muted); }
    .img-state-err { color: var(--mp-danger); }
    .img-spinner { width: 22px; height: 22px; border-radius: 50%; border: 2.5px solid var(--mp-border); border-top-color: var(--mp-primary); animation: img-spin .8s linear infinite; }
    @@keyframes img-spin { to { transform: rotate(360deg); } }
    .img-retry { border: 1px solid var(--mp-danger); background: transparent; color: var(--mp-danger); border-radius: var(--mp-radius-md); padding: 3px 10px; font-size: 11px; cursor: pointer; }

    .img-choice { display: inline-flex; margin-top: var(--mp-space-2); border: 1px solid var(--mp-border); border-radius: 999px; overflow: hidden; }
    .img-choice-btn { border: none; background: var(--mp-surface); color: var(--mp-text); padding: 6px 16px; font-size: 12px; font-weight: 600; cursor: pointer; }
    .img-choice-btn.active { background: var(--mp-primary); color: #fff; }
    .img-setprimary { display: block; margin-top: var(--mp-space-2); border: 1px solid var(--mp-border); background: var(--mp-surface); color: var(--mp-primary-dark); border-radius: var(--mp-radius-md); padding: 6px 12px; font-size: 12px; font-weight: 600; cursor: pointer; }
    .img-setprimary:hover { border-color: var(--mp-primary); }
</style>

@if (_loadError is not null)
{
    <ErrorNotice Title="Produits indisponibles" Message="@_loadError" OnRetry="Load" />
}
else if (_products is null)
{
    <p class="mp-caption">Chargement…</p>
}
else
{
    <div class="filter-bar">
        <button class="chip @(_filter is null ? "chip-active" : null)" @onclick="@(() => SetStockFilter(null))">
            Tous (@_products.Count)
        </button>
        <button class="chip @(_filter == StockStatus.InStock ? "chip-active" : null)" @onclick="@(() => SetStockFilter(StockStatus.InStock))">
            En stock (@_products.Count(p => p.StockStatus == StockStatus.InStock))
        </button>
        <button class="chip @(_filter == StockStatus.LowStock ? "chip-active" : null)" @onclick="@(() => SetStockFilter(StockStatus.LowStock))">
            Stock faible (@_products.Count(p => p.StockStatus == StockStatus.LowStock))
        </button>
        <button class="chip @(_filter == StockStatus.OutOfStock ? "chip-active" : null)" @onclick="@(() => SetStockFilter(StockStatus.OutOfStock))">
            Rupture (@_products.Count(p => p.StockStatus == StockStatus.OutOfStock))
        </button>
        <input class="mp-input prod-search" placeholder="Rechercher un nom ou un SKU…"
               value="@_search" @oninput="OnSearchChanged" />
    </div>

    <div class="prod-cards">
        @foreach (var p in Paged)
        {
            <div class="prod-card">
                <a class="prod-thumb" href="produit/@p.Id" aria-label="@p.Name">
                    @if (!string.IsNullOrEmpty(p.PrimaryImage?.Url))
                    {
                        <img src="@p.PrimaryImage!.Url" alt="@p.Name" />
                    }
                    else
                    {
                        <span class="prod-emoji" aria-hidden="true">@p.Emoji</span>
                    }
                </a>
                <button class="prod-del" type="button" title="Supprimer" @onclick="@(() => AskDelete(p))">
                    <AppIcon Name="trash" Size="16" />
                </button>
                <div class="prod-body">
                    <a class="prod-name" href="produit/@p.Id">@p.Name</a>
                    <div class="prod-price mp-num">@PriceLabel(p)</div>
                    <StockBadge Status="p.StockStatus" Stock="p.Stock" />
                </div>
            </div>
        }
        @if (!Filtered.Any())
        {
            <div class="empty-state">Aucun produit ne correspond à votre recherche.</div>
        }
    </div>

    @if (PageCount > 1)
    {
        <div class="prod-pager">
            <button class="prod-page-btn" type="button" disabled="@(_page <= 1)" @onclick="PrevPage">Précédent</button>
            <span class="mp-caption">Page @_page / @PageCount</span>
            <button class="prod-page-btn" type="button" disabled="@(_page >= PageCount)" @onclick="NextPage">Suivant</button>
        </div>
    }
}

<style>
    .prod-search { flex: 1 1 220px; max-width: 320px; margin-left: auto; }
    .prod-pager { display: flex; align-items: center; justify-content: center; gap: var(--mp-space-4); margin-top: var(--mp-space-4); }
    .prod-page-btn { border: 0.5px solid var(--mp-border); background: var(--mp-surface); border-radius: var(--mp-radius-md); padding: 6px 16px; font-size: 13px; cursor: pointer; color: var(--mp-text); }
    .prod-page-btn:hover:not(:disabled) { border-color: var(--mp-primary); color: var(--mp-primary); }
    .prod-page-btn:disabled { opacity: .5; cursor: default; }

    /* ---- Mobile : grille produits sur 2 colonnes (comme l'app cliente) ---- */
    @@media (max-width: 640.98px) {
        .prod-cards { grid-template-columns: repeat(2, 1fr); gap: var(--mp-space-3); }
        .prod-thumb { font-size: 34px; }
        .prod-name { font-size: 13px; }
        .prod-price { font-size: 15px; }

        .mp-table.products-table { min-width: 0; }
        .products-table thead { display: none; }
        .products-table, .products-table tbody, .products-table tr, .products-table td { display: block; width: auto; }
        .products-table tr {
            border: 0.5px solid var(--mp-border);
            border-radius: var(--mp-radius-lg);
            padding: var(--mp-space-2) var(--mp-space-3);
            margin: var(--mp-space-3);
            background: var(--mp-surface);
        }
        .products-table tbody tr:hover { background: var(--mp-surface); }
        .products-table td {
            display: flex; align-items: center; justify-content: space-between; gap: var(--mp-space-3);
            padding: 7px 0; border: none; text-align: right; white-space: normal;
        }
        .products-table td + td { border-top: 0.5px solid var(--mp-border); }
        .products-table td[data-label]::before {
            content: attr(data-label);
            font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: .04em;
            color: var(--mp-text-muted); text-align: left; flex-shrink: 0;
        }
        /* Cellule produit (image + nom) en en-tête pleine largeur */
        .products-table td.cell-prod { padding-top: 2px; }
        .products-table td.cell-prod .prod-name { font-size: 15px; }
        /* Actions : deux boutons côte à côte, pleine largeur */
        .products-table td.cell-actions { padding-top: var(--mp-space-2); gap: var(--mp-space-2); }
        .products-table td.cell-actions::before { display: none; }
        .products-table td.cell-actions button { flex: 1; width: auto; }
    }
</style>
