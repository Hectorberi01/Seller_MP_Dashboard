@page "/avis"
@inject ISellerApi Api

<PageTitle>Avis — Espace Vendeur</PageTitle>

<PageHeader 
    Title="Avis clients"
    Subtitle="Répondez aux avis et signalez les contenus abusifs." />

@if (_loadError is not null)
{
    <ErrorNotice Title="Avis indisponibles" Message="@_loadError" OnRetry="Reload" />
}
else if (_reviews is null || _rating is null)
{
    <p class="mp-caption">Chargement…</p>
}
else
{
    <div class="avis-grid">
        <MpCard Title="Note moyenne" Subtitle="@($"{_rating.Count} avis")">
            <ChildContent>
                <div class="rating-summary">
                    <div class="rating-avg mp-num">@_rating.Average.ToString("0.0")</div>
                    <div class="rating-stars">@Stars((int)Math.Round(_rating.Average))</div>
                </div>
                <div class="rating-breakdown">
                    @for (int star = 5; star >= 1; star--)
                    {
                        var count = _rating.Breakdown[star - 1];
                        var pct = _rating.Count > 0 ? (double)count / _rating.Count * 100 : 0;
                        <div class="bd-row">
                            <span class="bd-star mp-num">@star★</span>
                            <div class="bd-track"><div class="bd-fill" style="width:@pct.ToString("0.#", System.Globalization.CultureInfo.InvariantCulture)%"></div></div>
                            <span class="bd-count mp-num">@count</span>
                        </div>
                    }
                </div>
            </ChildContent>
        </MpCard>

        <div class="review-list">
            <div class="avis-toolbar">
                <div class="avis-filters">
                    @foreach (var f in _filters)
                    {
                        <button type="button" class="avis-chip @(_filter == f.Key ? "active" : "")"
                                @onclick="() => SetFilter(f.Key)">@f.Label</button>
                    }
                </div>
                <span class="mp-caption avis-count">@FilteredReviews.Count avis</span>
            </div>

            @if (FilteredReviews.Count == 0)
            {
                <MpCard>
                    <ChildContent>
                        <div class="avis-empty">
                            <span class="avis-empty-ico">
                                <svg viewBox="0 0 24 24" width="34" height="34" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.1 8.3 22 9.3 17 14.1 18.2 21 12 17.8 5.8 21 7 14.1 2 9.3 8.9 8.3 12 2"/></svg>
                            </span>
                            <span class="mp-body-strong">@(_reviews.Count == 0 ? "Aucun avis pour l'instant" : "Aucun avis correspondant")</span>
                            <span class="mp-caption">@(_reviews.Count == 0 ? "Les avis laissés par vos clients apparaîtront ici." : "Aucun avis ne correspond à ce filtre.")</span>
                        </div>
                    </ChildContent>
                </MpCard>
            }
            @foreach (var r in PagedReviews)
            {
                <MpCard>
                    <ChildContent>
                        <div class="rev-head">
                            <div>
                                <span class="rev-author">@r.Author</span>
                                <span class="rev-stars">@Stars(r.Rating)</span>
                            </div>
                            <span class="mp-caption mp-num">@Format.Date(r.CreatedAt)</span>
                        </div>
                        <p class="rev-body">@r.Body</p>

                        @if (r.Flagged)
                        {
                            <MpBadge Variant="BadgeVariant.Rupture" Icon="●">Signalé</MpBadge>
                        }

                        @if (r.SellerReply is not null)
                        {
                            <div class="rev-reply">
                                <span class="mp-caption">Votre réponse</span>
                                <p>@r.SellerReply</p>
                            </div>
                        }
                        else if (_replyingTo == r.Id)
                        {
                            <div class="reply-box">
                                <textarea class="mp-input" rows="2" @bind="_replyText" placeholder="Votre réponse…"></textarea>
                                <div class="reply-actions">
                                    <MpButton Variant="ButtonVariant.Tertiary" OnClick="@(() => _replyingTo = Guid.Empty)">Annuler</MpButton>
                                    <MpButton Variant="ButtonVariant.Primary" OnClick="@(() => SubmitReply(r))">Envoyer</MpButton>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="rev-actions">
                                <MpButton Variant="ButtonVariant.Secondary" OnClick="@(() => StartReply(r))">Répondre</MpButton>
                                @if (!r.Flagged)
                                {
                                    <MpButton Variant="ButtonVariant.Tertiary" Icon="flag" OnClick="@(() => Flag(r))">Signaler</MpButton>
                                }
                            </div>
                        }
                    </ChildContent>
                </MpCard>
            }

            @if (ReviewsPageCount > 1)
            {
                <div class="avis-pager">
                    <button class="avis-page-btn" type="button" disabled="@(_page <= 1)" @onclick="PrevPage">Précédent</button>
                    <span class="mp-caption">Page @_page / @ReviewsPageCount</span>
                    <button class="avis-page-btn" type="button" disabled="@(_page >= ReviewsPageCount)" @onclick="NextPage">Suivant</button>
                </div>
            }
        </div>
    </div>
}

@code {
    // Filtre / pagination (côté client) — la logique métier reste dans Avis.razor.cs.
    private string _filter = "all";
    private int _page = 1;
    private const int ReviewsPageSize = 8;

    private readonly (string Key, string Label)[] _filters =
    {
        ("all", "Tous"),
        ("flagged", "Signalés"),
        ("noreply", "Sans réponse"),
    };

    private void SetFilter(string key) { _filter = key; _page = 1; }
    private void PrevPage() { if (_page > 1) _page--; }
    private void NextPage() { if (_page < ReviewsPageCount) _page++; }

    private List<Review> FilteredReviews
    {
        get
        {
            if (_reviews is null) return new();
            IEnumerable<Review> q = _reviews;
            q = _filter switch
            {
                "flagged" => q.Where(r => r.Flagged),
                "noreply" => q.Where(r => string.IsNullOrWhiteSpace(r.SellerReply)),
                _ => q,
            };
            return q.ToList();
        }
    }

    private int ReviewsPageCount => Math.Max(1, (int)Math.Ceiling(FilteredReviews.Count / (double)ReviewsPageSize));
    private IEnumerable<Review> PagedReviews => FilteredReviews.Skip((Math.Min(_page, ReviewsPageCount) - 1) * ReviewsPageSize).Take(ReviewsPageSize);
}
