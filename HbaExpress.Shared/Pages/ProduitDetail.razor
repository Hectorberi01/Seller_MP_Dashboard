    private async Task SaveVariant()
    {
        if (product is null) return;
        if (string.IsNullOrWhiteSpace(_variant.Sku)) { _variantError = "Le SKU de la variante est requis."; return; }

        var attrs = _variant.Attributes
            .Where(a => !string.IsNullOrWhiteSpace(a.Key))
            .GroupBy(a => a.Key.Trim())
            .ToDictionary(g => g.Key, g => g.Last().Value?.Trim() ?? "");

        var request = new VariantRequest(
            _variant.Sku.Trim(),
            attrs.Count > 0 ? attrs : null,
            string.IsNullOrWhiteSpace(_variant.Barcode) ? null : _variant.Barcode.Trim(),
            _variant.WeightGrams,
            _variant.LengthMm > 0 ? _variant.LengthMm : null,
            _variant.WidthMm > 0 ? _variant.WidthMm : null,
            _variant.HeightMm > 0 ? _variant.HeightMm : null);

        try
        {
            if (_variantEditId is { } vid)
            {
                await Api.UpdateVariantAsync(product.Id, vid, request);
            }
            else
            {
                await Api.AddVariantAsync(product.Id, request);
            }
            _showVariant = false;
            await ReloadProduct();
        }
        catch (Exception ex) { _variantError = ex.Message; }
    }

