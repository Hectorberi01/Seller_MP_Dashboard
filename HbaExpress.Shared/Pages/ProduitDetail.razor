@page "/produit/{Id:guid}"
@using Seller_MP_Dashboard.Api
@using Microsoft.AspNetCore.Components.Forms
@inject ISellerApi Api
@inject NavigationManager Nav
@inject IConfiguration Config
@inject Seller_MP_Dashboard.Services.ToastService Toast

<PageTitle>@(product?.Name ?? "Produit") — Espace Vendeur</PageTitle>

@if (_loading)
{
    <p class="mp-caption">Chargement…</p>
}
else if (product is null)
{
    <PageHeader Title="Produit introuvable"
                Subtitle="Ce produit n'existe pas ou n'appartient pas à votre boutique." />
    <MpButton Variant="ButtonVariant.Secondary" OnClick="@(() => Nav.NavigateTo("produits"))">← Retour aux produits</MpButton>
}
else
{
    <div class="breadcrumb">
        <a href="produits">Produits</a>
        <span aria-hidden="true">/</span>
        <span>@product.Name</span>
    </div>

    @* Barre d'actions pleine largeur : tous les boutons sur une ligne, alignée
       avec les sections en dessous. *@
    <div class="detail-actions">
        <MpButton Variant="ButtonVariant.Secondary" Icon="arrow-left" OnClick="@(() => Nav.NavigateTo("produits"))">Retour</MpButton>
        <MpButton Variant="ButtonVariant.Tertiary" Icon="eye" OnClick="@(() => Nav.NavigateTo($"produit/{Id}/apercu"))">Aperçu client</MpButton>
        @if (product.Status == "Draft")
        {
            @* La publication (mise en vitrine) est validée par l'administration. *@
            <MpBadge Variant="BadgeVariant.Neutral" Icon="●">En attente de validation</MpBadge>
        }
        @if (product.Status == "Active")
        {
            <MpButton Variant="ButtonVariant.Secondary" Icon="eye-off" OnClick="@(() => ChangeStatus("Draft"))">Retirer de la vente</MpButton>
        }
        @if (product.Status != "Archived")
        {
            <MpButton Variant="ButtonVariant.Tertiary" Icon="archive" OnClick="@(() => ChangeStatus("Archived"))">Archiver</MpButton>
        }
        <MpButton Variant="ButtonVariant.Primary" Icon="edit" OnClick="OpenEdit">Modifier</MpButton>
        <MpButton Variant="ButtonVariant.Action" Icon="plus" OnClick="OpenOffer">Ajouter une offre</MpButton>
        <MpButton Variant="ButtonVariant.Danger" Icon="trash" OnClick="DeleteProduct">Retirer</MpButton>
    </div>
    @if (_statusError is not null) { <p class="form-error">@_statusError</p> }

    <div class="detail-grid">
        <div class="gallery">
            <MpCard NoPadding="true">
                <ChildContent>
                    @if (!string.IsNullOrEmpty(CurrentImage?.Url))
                    {
                        <img class="detail-photo" src="@CurrentImage!.Url" alt="@(CurrentImage.AltText ?? product.Name)" />
                    }
                    else
                    {
                        <div class="detail-image" aria-hidden="true">@CurrentImageEmoji</div>
                    }
                </ChildContent>
            </MpCard>

            @if (product.Images.Count > 0)
            {
                <span class="gallery-caption mp-caption">@(CurrentImage?.AltText ?? product.Name) · @(selectedImage + 1)/@product.Images.Count</span>
            }

            @if (product.Images.Count > 1)
            {
                <div class="thumbs">
                    @for (int i = 0; i < product.Images.Count; i++)
                    {
                        var idx = i;
                        var img = product.Images[i];
                        <button type="button"
                                class="thumb @(idx == selectedImage ? "is-active" : null)"
                                title="@img.AltText"
                                @onclick="@(() => selectedImage = idx)">
                            @if (!string.IsNullOrEmpty(img.Url))
                            {
                                <img class="thumb-img" src="@img.Url" alt="@img.AltText" />
                            }
                            else
                            {
                                <span class="thumb-emoji" aria-hidden="true">@img.Emoji</span>
                            }
                            @if (img.IsPrimary)
                            {
                                <span class="thumb-primary" title="Image principale">●</span>
                            }
                        </button>
                    }
                </div>
            }

            <MpCard Title="Gérer les images" Subtitle="Ajoutez les photos du produit, réordonnez-les et définissez la photo principale (celle vue en premier par les acheteurs).">
                <ChildContent>
                    @if (_mediaError is not null) { <p class="form-error">@_mediaError</p> }
                    @if (product.Images.Count == 0)
                    {
                        <p class="mp-caption">Aucune image. Ajoutez-en une ci-dessous.</p>
                    }
                    else
                    {
                        <div class="media-list">
                            @for (int i = 0; i < product.Images.Count; i++)
                            {
                                var idx = i;
                                var img = product.Images[i];
                                <div class="media-row">
                                    @if (!string.IsNullOrEmpty(img.Url)) { <img class="media-mini" src="@img.Url" alt="" /> }
                                    <span class="media-pos mp-num">@(idx + 1)</span>
                                    @if (img.IsPrimary) { <MpBadge Variant="BadgeVariant.Verified">Principale</MpBadge> }
                                    <div class="media-actions">
                                        <button type="button" class="mini-btn" title="Monter" disabled="@(idx == 0)" @onclick="@(() => MoveImage(idx, -1))">
                                            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="19" x2="12" y2="5"/><polyline points="5 12 12 5 19 12"/></svg>
                                        </button>
                                        <button type="button" class="mini-btn" title="Descendre" disabled="@(idx == product.Images.Count - 1)" @onclick="@(() => MoveImage(idx, 1))">
                                            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><polyline points="19 12 12 19 5 12"/></svg>
                                        </button>
                                        @if (!img.IsPrimary)
                                        {
                                            <button type="button" class="mini-btn" title="Définir principale" @onclick="@(() => SetPrimary(img.Id))">
                                                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.1 8.3 22 9.3 17 14.1 18.2 21 12 17.8 5.8 21 7 14.1 2 9.3 8.9 8.3 12 2"/></svg>
                                            </button>
                                        }
                                        <button type="button" class="mini-btn danger" title="Supprimer" @onclick="@(() => RemoveImage(img.Id))"><AppIcon Name="trash" Size="14" /></button>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    <div class="add-img">
                        <input class="mp-input" @bind="_imgAlt" placeholder="Texte alternatif (alt) — optionnel" disabled="@_mediaBusy" />
                        <InputFile OnChange="OnImageSelected" accept="image/*" disabled="@_mediaBusy" />
                        @if (_mediaBusy)
                        {
                            <span class="mp-caption">Détourage en cours… (fond blanc)</span>
                        }
                        else
                        {
                            <span class="mp-caption">Ajouter une image (détourée automatiquement sur fond blanc)</span>
                        }
                    </div>
                </ChildContent>
            </MpCard>
        </div>

        <div class="detail-info">
            <div class="detail-head">
                <h1>@product.Name</h1>
                <MpBadge Variant="@StatusVariant(product.Status)">@StatusLabel(product.Status)</MpBadge>
            </div>
            <MpCard Title="Description" Subtitle="Le texte descriptif présenté aux acheteurs. Utilisez « Modifier » (en haut) pour le compléter.">
                <ChildContent>
                    @if (string.IsNullOrWhiteSpace(product.Description))
                    {
                        <p class="mp-caption">Aucune description.</p>
                    }
                    else
                    {
                        <p class="desc-text">@product.Description</p>
                    }
                </ChildContent>
            </MpCard>

            <MpCard Title="Informations" Subtitle="Récapitulatif technique du produit : catégorie, marque, identifiants (GTIN/EAN) et nombre de photos.">
                <ChildContent>
                    <dl class="spec-list">
                        @if (!string.IsNullOrWhiteSpace(product.Sku))
                        {
                            <div><dt>Référence (SKU)</dt><dd class="mp-num">@product.Sku</dd></div>
                        }
                        <div><dt>Statut</dt><dd>@StatusLabel(product.Status)</dd></div>
                        <div><dt>GTIN</dt><dd class="mp-num">@(string.IsNullOrWhiteSpace(product.Gtin) ? "—" : product.Gtin)</dd></div>
                        <div><dt>EAN</dt><dd class="mp-num">@(string.IsNullOrWhiteSpace(product.Ean) ? "—" : product.Ean)</dd></div>
                        <div><dt>Photos</dt><dd class="mp-num">@product.Images.Count</dd></div>
                    </dl>
                </ChildContent>
            </MpCard>

            @if (product.Tags.Count > 0)
            {
                <div class="tag-row">
                    @foreach (var t in product.Tags)
                    {
                        <span class="tag-chip">@t</span>
                    }
                </div>
            }

        </div>
    </div>

    <div class="section-gap"></div>

    <MpCard Title="@($"Variantes ({product.Variants.Count})")" Subtitle="Les déclinaisons du produit (taille, couleur…). Chaque variante a son propre SKU et son propre stock. Ajoutez-en si le produit existe en plusieurs versions.">
        <HeaderContent>
            <MpButton Variant="ButtonVariant.Action" Icon="plus" OnClick="OpenVariant">Ajouter une variante</MpButton>
        </HeaderContent>
        <ChildContent>
            @if (product.Variants.Count == 0) { <p class="mp-caption">Aucune variante.</p> }
            else
            {
                <table class="mp-table stack-mobile">
                    <thead><tr><th>SKU</th><th>Attributs</th><th>Code-barres</th><th class="mp-num">Poids</th><th class="actions-col">Actions</th></tr></thead>
                    <tbody>
                        @foreach (var v in product.Variants)
                        {
                            <tr>
                                <td class="mp-num st-title" data-label="SKU">@v.Sku</td>
                                <td data-label="Attributs">@v.AttributesLabel</td>
                                <td class="mp-num" data-label="Code-barres">@(string.IsNullOrWhiteSpace(v.Barcode) ? "—" : v.Barcode)</td>
                                <td class="mp-num" data-label="Poids">@v.WeightGrams g</td>
                                <td class="actions-col st-actions">
                                    <div class="row-actions">
                                        <MpButton Variant="ButtonVariant.Tertiary" OnClick="@(() => OpenEditVariant(v))">Modifier</MpButton>
                                        <MpButton Variant="ButtonVariant.Danger" OnClick="@(() => RemoveVariant(v.Id))">Supprimer</MpButton>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </ChildContent>
    </MpCard>

    <MpModal @bind-Visible="_showVariant" Title="@(_variantEditId is null ? "Ajouter une variante" : "Modifier la variante")">
        <ChildContent>
            <div class="mp-form">
                <div class="mp-field">
                    <label>SKU <span class="mp-caption">(généré, modifiable)</span></label>
                    <div class="sku-row">
                        <input class="mp-input" @bind="_variant.Sku" placeholder="Ex. CHAUS-A1B2" />
                        <button type="button" class="sku-regen" title="Régénérer" @onclick="@(() => _variant.Sku = GenerateSku(product?.Name))"><svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg></button>
                    </div>
                </div>
                <div class="mp-grid-2">
                    <div class="mp-field">
                        <label>Code-barres <span class="mp-caption">(EAN-13, généré)</span></label>
                        <div class="sku-row">
                            <input class="mp-input" @bind="_variant.Barcode" />
                            <button type="button" class="sku-regen" title="Régénérer" @onclick="@(() => _variant.Barcode = GenerateBarcode())"><svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg></button>
                        </div>
                    </div>
                    <div class="mp-field"><label>Poids (g)</label><input class="mp-input" type="number" min="0" @bind="_variant.WeightGrams" /></div>
                </div>
                @if (_variantEditId is null)
                {
                    <div class="mp-field">
                        <label>Dimensions (mm) <span class="mp-caption">Longueur × Largeur × Hauteur</span></label>
                        <div class="mp-grid-3">
                            <input class="mp-input" type="number" min="0" placeholder="Longueur" @bind="_variant.LengthMm" />
                            <input class="mp-input" type="number" min="0" placeholder="Largeur" @bind="_variant.WidthMm" />
                            <input class="mp-input" type="number" min="0" placeholder="Hauteur" @bind="_variant.HeightMm" />
                        </div>
                    </div>
                }
                <div class="mp-field">
                    <label>Attributs <span class="mp-caption">(ex. Taille / 42, Couleur / Noir)</span></label>
                    @foreach (var a in _variant.Attributes)
                    {
                        <div class="attr-row">
                            <input class="mp-input" placeholder="Taille" @bind="a.Key" />
                            <input class="mp-input" placeholder="42" @bind="a.Value" />
                            <button type="button" class="mini-btn danger" title="Retirer" @onclick="@(() => _variant.Attributes.Remove(a))"><AppIcon Name="x" Size="14" /></button>
                        </div>
                    }
                    <button type="button" class="sku-regen sku-regen-txt" @onclick="@(() => _variant.Attributes.Add(new ProductAttribute()))"><AppIcon Name="plus" Size="14" /> Ajouter un attribut</button>
                </div>
                @if (_variantError is not null) { <p class="form-error">@_variantError</p> }
            </div>
        </ChildContent>
        <Footer>
            <MpButton Variant="ButtonVariant.Secondary" OnClick="@(() => _showVariant = false)">Annuler</MpButton>
            <MpButton Variant="ButtonVariant.Primary" OnClick="SaveVariant">@(_variantEditId is null ? "Créer la variante" : "Enregistrer")</MpButton>
        </Footer>
    </MpModal>

    <div class="section-gap"></div>

    <MpCard Title="Stock &amp; inventaire" Subtitle="Suivez les quantités par lieu d'expédition. « Réceptionner » ajoute du stock entrant, « Ajuster ± » corrige une quantité (perte, inventaire), et « Seuil » déclenche l'alerte de réapprovisionnement.">
        <ChildContent>
            @if (product.Variants.Count == 0)
            {
                <p class="mp-caption">Le stock se gère par SKU. Ajoutez d'abord une variante.</p>
            }
            else
            {
                <div class="mp-field stock-sku">
                    <label>Variante (SKU)</label>
                    <select class="mp-select" @bind="_stockSku" @bind:after="LoadStock">
                        @foreach (var v in product.Variants)
                        {
                            <option value="@v.Sku">@v.Sku @(v.AttributesLabel is "—" or "" ? "" : "· " + v.AttributesLabel)</option>
                        }
                    </select>
                </div>

                @if (_stockError is not null) { <p class="form-error">@_stockError</p> }
                @if (_stockItems is null) { <p class="mp-caption">Chargement…</p> }
                else
                {
                    @if (_stockItems.Count == 0) { <p class="mp-caption">Aucun article de stock pour ce SKU.</p> }
                    else
                    {
                        <table class="mp-table stack-mobile">
                            <thead><tr><th>Lieu</th><th class="mp-num">En stock</th><th class="mp-num">Réservé</th><th class="mp-num">Dispo</th><th>Seuil</th><th class="actions-col">Réapprovisionner</th></tr></thead>
                            <tbody>
                                @foreach (var it in _stockItems)
                                {
                                    <tr>
                                        <td class="st-title" data-label="Lieu">@LocationName(it.LocationId)</td>
                                        <td class="mp-num" data-label="En stock">@it.OnHand</td>
                                        <td class="mp-num" data-label="Réservé">@it.Reserved</td>
                                        <td class="mp-num" data-label="Dispo">@it.Available @if (it.IsLowStock) { <MpBadge Variant="BadgeVariant.Rupture">Bas</MpBadge> }</td>
                                        <td data-label="Seuil">
                                            <div class="thr-row">
                                                <input class="mp-input qty" type="number" min="0" @bind="_thrVal[it.Id]" />
                                                <button type="button" class="mini-btn" title="Définir le seuil" @onclick="@(() => SetThreshold(it.Id))"><AppIcon Name="check" Size="14" /></button>
                                            </div>
                                        </td>
                                        <td class="actions-col st-actions">
                                            <div class="stock-ops">
                                                <div class="row-actions stock-recv">
                                                    <input class="mp-input qty" type="number" min="1" @bind="_recvQty[it.Id]" />
                                                    <MpButton Variant="ButtonVariant.Primary" OnClick="@(() => Receive(it.Id))">Réceptionner</MpButton>
                                                </div>
                                                <div class="row-actions stock-recv">
                                                    <input class="mp-input qty" type="number" @bind="_adjVal[it.Id]" title="Ajustement (peut être négatif)" />
                                                    <MpButton Variant="ButtonVariant.Secondary" OnClick="@(() => Adjust(it.Id))">Ajuster ±</MpButton>
                                                </div>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }

                    <div class="stock-add">
                        <span class="stock-add-title">Créer un article de stock</span>
                        <p class="mp-caption stock-add-help">Reliez cette variante à un lieu d'expédition pour commencer à suivre son stock (quantité de départ + seuil d'alerte).</p>
                        <div class="mp-grid-3">
                            <div class="mp-field">
                                <label>Lieu d'expédition</label>
                                <select class="mp-select" @bind="_newStock.LocationId">
                                    <option value="">— Choisir un lieu —</option>
                                    @if (_locations is not null)
                                    {
                                        @foreach (var l in _locations) { <option value="@l.Id">@l.Line, @l.City</option> }
                                    }
                                </select>
                            </div>
                            <div class="mp-field">
                                <label>Quantité initiale</label>
                                <input class="mp-input" type="number" min="0" @bind="_newStock.OnHand" />
                            </div>
                            <div class="mp-field">
                                <label>Seuil de réappro.</label>
                                <input class="mp-input" type="number" min="0" @bind="_newStock.Threshold" />
                            </div>
                        </div>
                        <MpButton Variant="ButtonVariant.Action" Icon="plus" OnClick="CreateStock">Créer l'article</MpButton>
                    </div>
                }
            }
        </ChildContent>
    </MpCard>

    <div class="section-gap"></div>

    <MpCard Title="@($"Offres ({( _offers?.Count ?? 0)})")" Subtitle="Le prix de vente et l'état (neuf, occasion…) proposés aux acheteurs. Une offre « Active » rend le produit achetable ; sans offre active, il n'est pas vendu.">
        <ChildContent>
            @if (_offers is null) { <p class="mp-caption">Chargement…</p> }
            else if (_offers.Count == 0) { <p class="mp-caption">Aucune offre. Cliquez sur « Ajouter une offre ».</p> }
            else
            {
                <table class="mp-table stack-mobile">
                    <thead><tr><th>SKU</th><th class="mp-num">Prix</th><th>Condition</th><th>Statut</th><th class="actions-col">Actions</th></tr></thead>
                    <tbody>
                        @foreach (var o in _offers)
                        {
                            <tr>
                                <td class="mp-num st-title" data-label="SKU">@o.Sku</td>
                                <td class="mp-num" data-label="Prix">
                                    <div class="price-cell">
                                        <span class="price-main">@o.EffectiveProductPrice.ToString("N0") @o.Currency</span>
                                        <span class="price-sub mp-caption">dont @o.EffectiveSellerPrice.ToString("N0") @o.Currency pour vous (prix vendeur)</span>
                                    </div>
                                </td>
                                <td data-label="Condition">@o.Condition</td>
                                <td data-label="Statut"><MpBadge Variant="@(o.Status == "active" || o.Status == "Active" ? BadgeVariant.Verified : BadgeVariant.Neutral)">@o.Status</MpBadge></td>
                                <td class="actions-col st-actions">
                                    <div class="row-actions">
                                        <MpButton Variant="ButtonVariant.Tertiary" OnClick="@(() => OpenEditOffer(o))">Modifier</MpButton>
                                        <MpButton Variant="ButtonVariant.Secondary" OnClick="@(() => ToggleOffer(o))">@(IsOfferActive(o.Status) ? "Suspendre" : "Activer")</MpButton>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </ChildContent>
    </MpCard>

    <div class="section-gap"></div>

    <MpCard Title="@($"Avis clients ({( _reviews?.Count ?? 0)})")" Subtitle="Les avis laissés par les acheteurs. Vous pouvez y répondre publiquement ou signaler un avis inapproprié.">
        <ChildContent>
            @if (_reviews is null) { <p class="mp-caption">Chargement…</p> }
            else if (_reviews.Count == 0) { <p class="mp-caption">Aucun avis sur ce produit.</p> }
            else
            {
                <div class="review-list">
                    @foreach (var r in _reviews)
                    {
                        <div class="review-row">
                            <div class="review-head">
                                <strong>@r.Author</strong>
                                <span class="mp-caption">★ @r.Rating · @r.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy")</span>
                                @if (r.Flagged)
                                {
                                    <MpBadge Variant="BadgeVariant.Rupture">Signalé</MpBadge>
                                }
                                else
                                {
                                    <button type="button" class="flag-btn" title="Signaler un avis inapproprié" @onclick="@(() => FlagReview(r.Id))"><AppIcon Name="flag" Size="14" /> Signaler</button>
                                }
                            </div>
                            <p class="review-body">@r.Body</p>
                            @if (!string.IsNullOrWhiteSpace(r.SellerReply))
                            {
                                <p class="review-reply"><strong>Votre réponse :</strong> @r.SellerReply</p>
                            }
                            else
                            {
                                <div class="reply-form">
                                    <input class="mp-input" placeholder="Répondre à cet avis…" @bind="_replyText[r.Id]" />
                                    <MpButton Variant="ButtonVariant.Primary" OnClick="@(() => Reply(r.Id))">Répondre</MpButton>
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        </ChildContent>
    </MpCard>

    <MpModal @bind-Visible="_showOfferEdit" Title="Modifier l'offre">
        <ChildContent>
            <div class="mp-form">
                <div class="price-info">
                    <span class="price-info-icon"><AppIcon Name="info" Size="16" /></span>
                    <p class="price-info-text">
                        Vous fixez votre <strong>prix vendeur</strong> (ce que vous recevez).
                        La plateforme ajoute @CommissionPct de commission et @ProviderPct de frais provider.
                        L'acheteur paie donc votre prix +@TotalPct.
                    </p>
                </div>
                <div class="mp-grid-2">
                    <div class="mp-field"><label>Prix vendeur <span class="mp-caption">(ce que vous touchez)</span></label><input class="mp-input" type="number" step="0.01" @bind="_offerEditPrice" @bind:event="oninput" /></div>
                    <div class="mp-field">
                        <label>Devise</label>
                        <select class="mp-select" @bind="_offerEditCurrency">
                            @foreach (var c in _currencies) { <option value="@c">@c</option> }
                        </select>
                    </div>
                </div>
                @PricePreview(_offerEditPrice, _offerEditCurrency)
                <div class="mp-field"><label>Délai de traitement (jours)</label><input class="mp-input" type="number" min="0" @bind="_offerEditHandling" /></div>
                @if (_offerEditError is not null) { <p class="form-error">@_offerEditError</p> }
            </div>
        </ChildContent>
        <Footer>
            <MpButton Variant="ButtonVariant.Secondary" OnClick="@(() => _showOfferEdit = false)">Annuler</MpButton>
            <MpButton Variant="ButtonVariant.Primary" OnClick="SaveOfferPrice">Enregistrer</MpButton>
        </Footer>
    </MpModal>

    <MpModal @bind-Visible="_showEdit" Title="Modifier la fiche produit">
        <ChildContent>
            <div class="mp-form">
                <div class="mp-field"><label>Nom</label><input class="mp-input" @bind="_edit.Name" /></div>
                <div class="mp-field"><label>Description</label><textarea class="mp-textarea" rows="3" @bind="_edit.Description"></textarea></div>
                <div class="mp-field">
                    <label>Marque</label>
                    <select class="mp-select" @bind="_edit.BrandId">
                        <option value="">— Aucune marque —</option>
                        @if (_brands is not null)
                        {
                            @foreach (var b in _brands) { <option value="@b.Id">@b.Name</option> }
                        }
                    </select>
                </div>
                <div class="mp-grid-2">
                    <div class="mp-field"><label>GTIN</label><input class="mp-input" @bind="_edit.Gtin" /></div>
                    <div class="mp-field"><label>EAN</label><input class="mp-input" @bind="_edit.Ean" /></div>
                </div>
                <div class="mp-field"><label>Tags <span class="mp-caption">(séparés par des virgules)</span></label><input class="mp-input" @bind="_edit.TagsText" /></div>
                <div class="mp-field"><label>Groupe de produit <span class="mp-caption">(GUID, optionnel)</span></label><input class="mp-input" @bind="_edit.ProductGroupIdText" placeholder="Laisser vide si non applicable" /></div>
                <div class="mp-field">
                    <label>Attributs <span class="mp-caption">(clé / valeur)</span></label>
                    @foreach (var a in _edit.Attributes)
                    {
                        <div class="attr-row">
                            <input class="mp-input" placeholder="Couleur" @bind="a.Key" />
                            <input class="mp-input" placeholder="Noir" @bind="a.Value" />
                            <button type="button" class="mini-btn danger" title="Retirer" @onclick="@(() => _edit.Attributes.Remove(a))"><AppIcon Name="x" Size="14" /></button>
                        </div>
                    }
                    <button type="button" class="sku-regen sku-regen-txt" @onclick="@(() => _edit.Attributes.Add(new ProductAttribute()))"><AppIcon Name="plus" Size="14" /> Ajouter un attribut</button>
                </div>
                @if (_editError is not null) { <p class="form-error">@_editError</p> }
            </div>
        </ChildContent>
        <Footer>
            <MpButton Variant="ButtonVariant.Secondary" OnClick="@(() => _showEdit = false)">Annuler</MpButton>
            <MpButton Variant="ButtonVariant.Primary" OnClick="SaveEdit">Enregistrer</MpButton>
        </Footer>
    </MpModal>

    <MpModal @bind-Visible="_showOffer" Title="Ajouter une offre">
        <ChildContent>
            <div class="mp-form">
                <div class="price-info">
                    <span class="price-info-icon"><AppIcon Name="info" Size="16" /></span>
                    <p class="price-info-text">
                        Vous fixez votre <strong>prix vendeur</strong> (ce que vous recevez).
                        La plateforme ajoute @CommissionPct de commission et @ProviderPct de frais provider.
                        L'acheteur paie donc votre prix +@TotalPct.
                    </p>
                </div>
                <div class="mp-field">
                    <label>SKU <span class="mp-caption">(généré, modifiable)</span></label>
                    <div class="sku-row">
                        <input class="mp-input" @bind="_offer.Sku" placeholder="Ex. CHAUS-A1B2" />
                        <button type="button" class="sku-regen" title="Régénérer" @onclick="RegenerateSku"><svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg></button>
                    </div>
                </div>
                <div class="mp-grid-2">
                    <div class="mp-field"><label>Prix vendeur <span class="mp-caption">(ce que vous touchez)</span></label><input class="mp-input" type="number" step="0.01" @bind="_offer.Price" @bind:event="oninput" /></div>
                    <div class="mp-field">
                        <label>Devise</label>
                        <select class="mp-select" @bind="_offer.Currency">
                            @foreach (var c in _currencies)
                            {
                                <option value="@c">@c</option>
                            }
                        </select>
                    </div>
                </div>
                @PricePreview(_offer.Price, _offer.Currency)
                <div class="mp-grid-2">
                    <div class="mp-field">
                        <label>Condition</label>
                        <select class="mp-select" @bind="_offer.Condition">
                            <option value="New">Neuf</option>
                            <option value="Used">Occasion</option>
                            <option value="Refurbished">Reconditionné</option>
                        </select>
                    </div>
                    <div class="mp-field">
                        <label>Traitement (jours)</label>
                        <input class="mp-input" type="number" min="0" @bind="_offer.HandlingTime" />
                    </div>
                </div>
                <div class="mp-field">
                    <label>Expédié depuis</label>
                    @if (_locations is null)
                    {
                        <p class="mp-caption">Chargement des lieux…</p>
                    }
                    else if (_locations.Count == 0)
                    {
                        <p class="form-error">Aucun lieu d'expédition. Créez-en un dans « Ma boutique » avant d'ajouter une offre.</p>
                    }
                    else
                    {
                        <select class="mp-select" @bind="_offer.LocationId">
                            <option value="">— Choisir un lieu —</option>
                            @foreach (var l in _locations)
                            {
                                <option value="@l.Id">@l.Line, @l.City (@l.Country)</option>
                            }
                        </select>
                    }
                </div>
                @if (_offerError is not null) { <p class="form-error">@_offerError</p> }
            </div>
        </ChildContent>
        <Footer>
            <MpButton Variant="ButtonVariant.Secondary" OnClick="@(() => _showOffer = false)">Annuler</MpButton>
            <MpButton Variant="ButtonVariant.Primary" OnClick="CreateOffer">Créer l'offre</MpButton>
        </Footer>
    </MpModal>
}

<style>
    .breadcrumb {
        display: flex;
        align-items: center;
        gap: var(--mp-space-2);
        font-size: 13px;
        color: var(--mp-text-muted);
        margin-bottom: var(--mp-space-4);
    }

    .detail-grid {
        display: grid;
        /* minmax(0, 1fr) : empêche la colonne de droite de déborder au-delà de la
           largeur du contenu (la barre d'actions en « nowrap » la faisait gonfler),
           pour que la rangée du haut reste alignée avec les cartes en dessous. */
        grid-template-columns: 360px minmax(0, 1fr);
        gap: var(--mp-space-6);
        align-items: start;
    }

    .gallery { display: flex; flex-direction: column; gap: var(--mp-space-2); }

    .detail-image {
        height: 320px;
        display: flex;
        align-items: center;
        justify-content: center;
