    /// <summary>Aperçu EN DIRECT du calcul : prix vendeur → commission → frais → prix acheteur.</summary>
    private RenderFragment PricePreview(double sellerPrice, string currency) => builder =>
    {
        var seller = sellerPrice > 0 ? sellerPrice : 0;
        var commission = OfferPricing.Commission(seller);
        var providerFee = OfferPricing.ProviderFee(seller);
        var productPrice = OfferPricing.ProductPrice(seller);
        var cur = string.IsNullOrWhiteSpace(currency) ? "XOF" : currency;

        builder.OpenElement(0, "div");
        builder.AddAttribute(1, "class", "price-preview");

        builder.OpenElement(2, "div");
        builder.AddAttribute(3, "class", "pp-row");
        builder.OpenElement(4, "span"); builder.AddContent(5, "Prix vendeur (ce que vous touchez)"); builder.CloseElement();
        builder.OpenElement(6, "span"); builder.AddAttribute(7, "class", "mp-num"); builder.AddContent(8, $"{seller:N0} {cur}"); builder.CloseElement();
        builder.CloseElement();

        builder.OpenElement(9, "div");
        builder.AddAttribute(10, "class", "pp-row pp-add");
        builder.OpenElement(11, "span"); builder.AddContent(12, $"Commission plateforme ({CommissionPct})"); builder.CloseElement();
        builder.OpenElement(13, "span"); builder.AddAttribute(14, "class", "mp-num"); builder.AddContent(15, $"+{commission:N0} {cur}"); builder.CloseElement();
        builder.CloseElement();

        builder.OpenElement(16, "div");
        builder.AddAttribute(17, "class", "pp-row pp-add");
        builder.OpenElement(18, "span"); builder.AddContent(19, $"Frais provider ({ProviderPct})"); builder.CloseElement();
        builder.OpenElement(20, "span"); builder.AddAttribute(21, "class", "mp-num"); builder.AddContent(22, $"+{providerFee:N0} {cur}"); builder.CloseElement();
        builder.CloseElement();

        builder.OpenElement(23, "div");
