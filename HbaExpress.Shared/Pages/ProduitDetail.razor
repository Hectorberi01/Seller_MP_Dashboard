    // ---------- Images ----------
    private async Task OnImageSelected(InputFileChangeEventArgs e)
    {
        _mediaError = null;
        if (product is null) return;
        try
        {
            var file = e.File;
            using var ms = new MemoryStream();
            await file.OpenReadStream(MaxImageBytes).CopyToAsync(ms);
            var upload = new ProductImageUpload
            {
                FileName = file.Name,
                ContentType = string.IsNullOrEmpty(file.ContentType) ? "image/jpeg" : file.ContentType,
                Content = ms.ToArray(),
                AltText = string.IsNullOrWhiteSpace(_imgAlt) ? null : _imgAlt.Trim()
            };

            // Détourage IA + fond blanc (comme à la création). En cas d'échec
            // (Cloudinary indispo/non configuré), on téléverse l'originale.
            _mediaBusy = true;
            StateHasChanged();
            try { upload = await Api.ProcessImageAsync(upload); }
            catch { /* repli : on garde l'originale */ }
            finally { _mediaBusy = false; }

            await Api.UploadImageAsync(product.Id, upload);
            _imgAlt = "";
            await ReloadProduct();
        }
        catch (Exception ex) { _mediaError = $"Échec de l'ajout : {ex.Message}"; }
        finally { _mediaBusy = false; }
    }

