@page "/commande/{Id:guid}"
@using Seller_MP_Dashboard.Api
@inject ISellerApi Api
@inject NavigationManager Nav

<PageTitle>@(order?.Reference ?? "Commande") — Espace Vendeur</PageTitle>

@if (loadError is not null)
{
    <ErrorNotice Title="Commande indisponible" Message="@loadError" OnRetry="Reload" />
}
else if (loading)
{
    <p class="mp-caption">Chargement…</p>
}
else if (order is null)
{
    <PageHeader Title="Commande introuvable"
                Subtitle="Aucune commande ne correspond à cette référence." />
    <MpButton Variant="ButtonVariant.Secondary" OnClick="@(() => Nav.NavigateTo("commandes"))">← Retour aux commandes</MpButton>
}
else
{
    <div class="breadcrumb">
        <a href="commandes">Commandes</a>
        <span aria-hidden="true">/</span>
        <span class="mp-num">@order.Reference</span>
    </div>

    <PageHeader Title="@order.Reference" Subtitle="@($"Passée le {Format.Date(order.Date)} par {order.Customer}")">
        <Actions>
            <OrderStatusBadge Payment="order.UiPayment" ShowPayment="true" />
            <OrderStatusBadge Status="order.UiStatus" />
        </Actions>
    </PageHeader>

    <div class="order-grid">
        <MpCard Title="Articles" NoPadding="true">
            <ChildContent>
                <table class="mp-table stack-mobile">
                    <thead>
                        <tr><th>Produit</th><th class="num">Qté</th><th class="num">Prix unitaire</th><th class="num">Total</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var line in order.Lines)
                        {
                            <tr>
                                <td>
                                    <div class="line-cell">
                                        <span class="line-thumb" aria-hidden="true">
                                            @if (!string.IsNullOrEmpty(line.ImageUrl))
                                            {
                                                <img class="line-img" src="@line.ImageUrl" alt="@line.ProductName" />
                                            }
                                            else
                                            {
                                                <span class="line-emoji">@line.Emoji</span>
                                            }
                                        </span>
                                        <div class="line-text">
                                            <span class="line-name">@line.ProductName</span>
                                            @if (!string.IsNullOrWhiteSpace(line.Sku))
                                            {
                                                <span class="line-sku mp-num">@line.Sku</span>
                                            }
                                        </div>
                                    </div>
                                </td>
                                <td class="num mp-num" data-label="Qté">@line.Qty</td>
                                <td class="num mp-num" data-label="Prix unitaire">@Format.Xof(line.UnitPriceXof)</td>
                                <td class="num mp-num mp-body-strong" data-label="Total">@Format.Xof(line.LineTotalXof)</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr>
                            <td colspan="3" class="num total-label">Total commande (vos lignes)</td>
                            <td class="num mp-num total-value">@Format.Xof(order.TotalXof)</td>
                        </tr>
                    </tfoot>
                </table>
            </ChildContent>
        </MpCard>

        <div class="order-side">
            <MpCard Title="Client">
                <ChildContent>
                    <dl class="kv">
                        <div><dt>Nom</dt><dd>@order.Customer</dd></div>
                        <div><dt>Articles</dt><dd class="mp-num">@order.ItemCount</dd></div>
                    </dl>
                </ChildContent>
            </MpCard>

            <MpCard Title="Adresse de livraison">
                <ChildContent>
                    @if (order.ShippingAddress is { HasContent: true } addr)
                    {
                        <address class="ship-addr">
                            @if (!string.IsNullOrWhiteSpace(addr.Recipient))
                            {
                                <div class="ship-recipient">@addr.Recipient</div>
                            }
                            @if (!string.IsNullOrWhiteSpace(addr.Line1))
                            {
                                <div>@addr.Line1</div>
                            }
                            @if (!string.IsNullOrWhiteSpace(addr.Line2))
                            {
                                <div>@addr.Line2</div>
                            }
                            @if (!string.IsNullOrWhiteSpace(addr.City) || !string.IsNullOrWhiteSpace(addr.Country))
                            {
                                <div>@($"{addr.City} {addr.Country}".Trim())</div>
                            }
                            @if (!string.IsNullOrWhiteSpace(addr.Phone))
                            {
                                <div class="ship-phone mp-num">@addr.Phone</div>
                            }
                        </address>
                    }
                    else
                    {
                        <p class="mp-caption ship-empty">Aucune adresse de livraison renseignée.</p>
                    }
                </ChildContent>
            </MpCard>

            <MpCard Title="Actions">
                <ChildContent>
                    <div class="order-actions">
                        @if (order.UiStatus is OrderStatus.Pending or OrderStatus.Processing)
                        {
                            @if (order.UiPayment == PaymentStatus.Paid)
                            {
                                <MpButton Variant="ButtonVariant.Primary" Icon="package" FullWidth="true" OnClick="@(() => Nav.NavigateTo("expeditions"))">Préparer l'expédition</MpButton>
                            }
                            else
                            {
                                <div class="pay-wait">
                                    <span class="pay-wait-ico"><AppIcon Name="alert-triangle" Size="16" /></span>
                                    <span>Paiement en attente — impossible de préparer l'expédition tant que le client n'a pas payé.</span>
                                </div>
                            }
                        }
                        <MpButton Variant="ButtonVariant.Secondary" FullWidth="true" OnClick="@(() => Nav.NavigateTo("messagerie"))">Contacter le client</MpButton>
                    </div>
                </ChildContent>
            </MpCard>
        </div>
    </div>
}

<style>
    .breadcrumb { display: flex; align-items: center; gap: var(--mp-space-2); font-size: 13px; color: var(--mp-text-muted); margin-bottom: var(--mp-space-4); }
    .order-grid { display: grid; grid-template-columns: 1.6fr 1fr; gap: var(--mp-space-4); align-items: start; }
    @@media (max-width: 900px) { .order-grid { grid-template-columns: 1fr; } }
    /* Mobile : la table articles s'empile (stack-mobile) ; le pied « Total » reste
       une ligne propre libellé↔montant au lieu de blocs séparés. */
    @@media (max-width: 640.98px) {
        .order-grid .stack-mobile tfoot tr { display: flex; align-items: center; justify-content: space-between; gap: var(--mp-space-3); border: none; margin: var(--mp-space-2) var(--mp-space-3) 0; padding: var(--mp-space-2) 0 0; border-top: 0.5px solid var(--mp-border); }
        .order-grid .stack-mobile tfoot td { border: none; padding: 0; }
        .order-grid .stack-mobile tfoot .total-value { font-size: 16px; }
    }
    .order-side { display: flex; flex-direction: column; gap: var(--mp-space-4); }
    .line-cell { display: flex; align-items: center; gap: var(--mp-space-3); }
    .line-thumb { flex: 0 0 auto; width: 44px; height: 44px; border-radius: var(--mp-radius-md); background: var(--mp-surface-2, #f4f5f7); border: 0.5px solid var(--mp-border); display: flex; align-items: center; justify-content: center; overflow: hidden; }
    .line-img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .line-emoji { font-size: 22px; }
    .line-text { display: flex; flex-direction: column; }
    .line-name { font-weight: 500; }
    .line-sku { font-size: 12px; color: var(--mp-text-muted); }
    .ship-addr { font-style: normal; font-size: 14px; line-height: 1.5; }
    .ship-recipient { font-weight: 600; }
    .ship-phone { color: var(--mp-text-muted); margin-top: var(--mp-space-1); }
    .ship-empty { margin: 0; }
    .mp-table tfoot td { padding: var(--mp-space-3) var(--mp-space-4); border-top: 0.5px solid var(--mp-border); }
    .total-label { color: var(--mp-text-muted); }
    .total-value { font-size: 18px; font-weight: 700; color: var(--mp-primary-dark); }
    .kv { display: flex; flex-direction: column; margin: 0; }
    .kv > div { display: flex; justify-content: space-between; gap: var(--mp-space-4); padding: var(--mp-space-2) 0; border-bottom: 0.5px solid var(--mp-border); }
    .kv > div:last-child { border-bottom: 0; }
    .kv dt { color: var(--mp-text-muted); font-size: 14px; }
    .kv dd { margin: 0; font-weight: 500; text-align: right; }
    .order-actions { display: flex; flex-direction: column; gap: var(--mp-space-2); }
    .pay-wait {
        display: flex; align-items: flex-start; gap: var(--mp-space-2);
        background-color: var(--mp-badge-attente-bg, #FDF6E3);
        border: 0.5px solid var(--mp-border);
        border-radius: var(--mp-radius-md);
        padding: var(--mp-space-3);
        font-size: 13px; color: var(--mp-text);
    }
    .pay-wait-ico { color: #E8A33D; flex: 0 0 auto; display: inline-flex; margin-top: 1px; }
</style>

@code {
    [Parameter] public Guid Id { get; set; }
    private SellerOrder? order;
    private bool loading = true;
    private string? loadError;

    protected override Task OnParametersSetAsync() => Reload();

    private async Task Reload()
    {
        loading = true;
        loadError = null;
        try { order = await Api.GetOrderAsync(Id); }
        catch (Exception ex) { loadError = ex.Message; }
        finally { loading = false; }
    }
}
