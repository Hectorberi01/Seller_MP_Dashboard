@page "/"
@using System.Globalization
@using Seller_MP_Dashboard.Api
@inject ISellerApi Api
@inject AuthState Auth
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Tableau de bord — HbaExpress Pro</PageTitle>

@if (loadError is not null)
{
    <ErrorNotice Title="Tableau de bord indisponible" Message="@loadError" OnRetry="Reload" />
}
else if (kpis is null)
{
    <p class="mp-caption">Chargement…</p>
}
else
{
    <div class="home-header">
        <div class="home-header-txt">
            <h1>Bonjour, @DisplayName</h1>
            <span class="mp-pill mp-pill--green">
                <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                Boutique vérifiée
            </span>
        </div>
        <div class="home-header-actions">
            <MpButton Variant="ButtonVariant.Secondary" Icon="wallet" OnClick="@(() => Nav.NavigateTo("portefeuille"))">Retrait portefeuille</MpButton>
            <MpButton Variant="ButtonVariant.Primary" Icon="plus" OnClick="@(() => Nav.NavigateTo("produits"))">Ajouter un produit</MpButton>
        </div>
    </div>

    <div class="kpi-grid">
        <div class="kpi-card">
            <div class="kpi-ico kpi-ico-green" aria-hidden="true" style="color:var(--mp-primary)">
                <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="6" width="20" height="12" rx="2"/><circle cx="12" cy="12" r="2.2"/><path d="M6 12h.01M18 12h.01"/></svg>
            </div>
            <div class="kpi-body">
                <span class="kpi-label">Chiffre d'affaires</span>
                <span class="kpi-value mp-num" data-countup>@Format.Xof((int)kpis.GrossSales30d)</span>
                <span class="kpi-tag up">30 derniers jours</span>
            </div>
        </div>
        <div class="kpi-card">
            <div class="kpi-ico kpi-ico-amber" aria-hidden="true" style="color:var(--mp-badge-promo-tx)">
                <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></svg>
            </div>
            <div class="kpi-body">
                <span class="kpi-label">Commandes à expédier</span>
                <span class="kpi-value mp-num" data-countup>@kpis.OrdersToProcess</span>
                <span class="kpi-tag neutral">à traiter</span>
            </div>
        </div>
        <div class="kpi-card">
            <div class="kpi-ico kpi-ico-yellow" aria-hidden="true" style="color:#E8A33D">
                <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.1 8.3 22 9.3 17 14.1 18.2 21 12 17.8 5.8 21 7 14.1 2 9.3 8.9 8.3 12 2"/></svg>
            </div>
            <div class="kpi-body">
                <span class="kpi-label">Note moyenne</span>
                <span class="kpi-value mp-num" data-countup>@kpis.AverageRating.ToString("0.0", CultureInfo.InvariantCulture)/5</span>
                <span class="kpi-tag neutral">@kpis.ReviewsCount avis</span>
            </div>
        </div>
        <div class="kpi-card">
            <div class="kpi-ico kpi-ico-blue" aria-hidden="true" style="color:var(--mp-primary-dark)">
                <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M16 2H8a2 2 0 0 0-2 2v18l3-2 2 2 2-2 2 2 3-2V4a2 2 0 0 0-2-2Z"/><path d="M9 7h6M9 11h6"/></svg>
            </div>
            <div class="kpi-body">
                <span class="kpi-label">Ventes du mois</span>
                <span class="kpi-value mp-num" data-countup>@kpis.OrdersTotal</span>
                <span class="kpi-tag neutral">commandes</span>
            </div>
        </div>
    </div>

    <div class="home-grid">
        <div class="home-col-main">
            <MpCard Title="Ventes sur les 7 derniers jours" Subtitle="Montant encaissé par jour (XOF)">
                <div class="chart-wrap">
                    <canvas id="salesLineChart"></canvas>
                </div>
            </MpCard>

            <MpCard Title="Commandes récentes" Subtitle="Vos dernières commandes reçues">
                <HeaderContent>
                    <MpButton Variant="ButtonVariant.Tertiary" OnClick="@(() => Nav.NavigateTo("commandes"))">Tout voir →</MpButton>
                </HeaderContent>
                <ChildContent>
                    @if (orders is null || orders.Count == 0)
                    {
                        <p class="mp-caption">Aucune commande pour l'instant.</p>
                    }
                    else
                    {
                        <div class="mp-list recent-list">
                            @foreach (var o in orders.Take(6))
                            {
                                <a class="mp-list-row" href="commande/@o.Id">
                                    <span class="mp-tile mp-tile--round mp-tile--blue" aria-hidden="true">
                                        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="8" y="2" width="8" height="4" rx="1"/><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><path d="M9 12h6M9 16h6"/></svg>
                                    </span>
                                    <div class="mp-list-main">
                                        <span class="mp-list-title mp-num">@o.Reference</span>
                                        <span class="mp-list-sub">@o.Customer</span>
                                    </div>
                                    <div class="mp-list-trail">
                                        <div class="mp-num mp-body-strong">@Format.Xof(o.TotalXof)</div>
                                        <OrderStatusBadge Status="o.UiStatus" />
                                    </div>
                                </a>
                            }
                        </div>
                    }
                </ChildContent>
            </MpCard>
        </div>

        <div class="home-col-side">
            <MpCard Title="Stock Critique" Subtitle="Produits à réapprovisionner">
                <div class="stock-list">
                    @if (lowStock.Count == 0)
                    {
                        <p class="mp-caption" style="display:inline-flex;align-items:center;gap:.35rem">Aucun produit en stock faible. <AppIcon Name="check" Size="16" /></p>
                    }
                    else
                    {
                        @foreach (var p in lowStock)
                        {
                            <div class="stock-row">
                                <div class="stock-main">
                                    <span class="stock-name">@p.Name</span>
                                    <span class="stock-sku mp-caption">@p.Sku</span>
                                </div>
                                <div class="stock-side">
                                    <span class="stock-qty @(p.Stock <= 0 ? "out" : "low")">@p.Stock restants</span>
                                    <a class="stock-link" href="produits">Gérer →</a>
                                </div>
                            </div>
                        }
                    }
                </div>
            </MpCard>

            <div class="promo-card">
                <div class="promo-deco" aria-hidden="true"></div>
                <div class="promo-content">
                    <span class="promo-emoji" aria-hidden="true" style="color:#fff">
                        <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="m3 11 18-5v12L3 14v-3z"/><path d="M11.6 16.8a3 3 0 1 1-5.8-1.6"/></svg>
                    </span>
                    <h3 class="promo-title">Boostez votre boutique !</h3>
                    <p class="promo-text">Mettez vos produits en avant et touchez plus de clients grâce à nos outils marketing.</p>
                    <button class="promo-btn" type="button" @onclick="@(() => Nav.NavigateTo("boutique"))">En savoir plus</button>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .home-header { display: flex; align-items: flex-start; justify-content: space-between; gap: var(--mp-space-4); flex-wrap: wrap; margin-bottom: var(--mp-space-6); }
    .home-header h1 { font-size: 24px; }
    .home-header-txt p { margin: 4px 0 0 0; }
    .home-header-actions { display: flex; gap: var(--mp-space-2); flex-wrap: wrap; }

    .kpi-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: var(--mp-space-3); margin-bottom: var(--mp-space-5); }
    .kpi-card { display: flex; flex-direction: column; align-items: flex-start; gap: var(--mp-space-2); background-color: var(--mp-surface); border: 1px solid var(--mp-border); border-radius: var(--mp-radius-lg); box-shadow: var(--mp-shadow-sm); padding: var(--mp-space-4); }
    .kpi-ico { display: inline-flex; align-items: center; justify-content: center; width: 2.75rem; height: 2.75rem; border-radius: var(--mp-radius-md); font-size: 1.25rem; flex-shrink: 0; }
    .kpi-ico-green  { background-color: var(--mp-tile-green-bg); color: var(--mp-tile-green-fg) !important; }
    .kpi-ico-amber  { background-color: var(--mp-tile-amber-bg); color: var(--mp-tile-amber-fg) !important; }
    .kpi-ico-yellow { background-color: #FEF3D6; }
    .kpi-ico-blue   { background-color: var(--mp-tile-blue-bg); color: var(--mp-tile-blue-fg) !important; }
    .kpi-body { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
    .kpi-label { font-size: 13px; color: var(--mp-text-muted); }
    .kpi-value { font-size: 22px; font-weight: 700; color: var(--mp-primary-dark); line-height: 1.15; }
    .kpi-tag { font-size: 12px; font-weight: 600; margin-top: 2px; align-self: flex-start; padding: 2px 8px; border-radius: 999px; }
    .kpi-tag.up { color: var(--mp-primary-dark); background-color: var(--mp-primary-light); }
    .kpi-tag.neutral { color: var(--mp-text-muted); background-color: var(--mp-surface-2); }

    .home-grid { display: grid; grid-template-columns: 2fr 1fr; gap: var(--mp-space-4); align-items: start; margin-bottom: var(--mp-space-4); }
    .home-col-main { display: flex; flex-direction: column; gap: var(--mp-space-4); }
    .home-col-side { display: flex; flex-direction: column; gap: var(--mp-space-4); }
    .chart-wrap { position: relative; height: 260px; width: 100%; }

    .stock-list { display: flex; flex-direction: column; }
    .stock-row { display: flex; align-items: center; justify-content: space-between; gap: var(--mp-space-3); padding: var(--mp-space-3) 0; border-bottom: 0.5px solid var(--mp-border); }
    .stock-row:last-child { border-bottom: 0; }
    .stock-main { display: flex; flex-direction: column; gap: 1px; min-width: 0; }
    .stock-name { font-weight: 500; }
    .stock-side { display: flex; flex-direction: column; align-items: flex-end; gap: 2px; }
    .stock-qty { font-size: 13px; font-weight: 600; white-space: nowrap; }
    .stock-qty.low { color: var(--mp-badge-promo-tx); }
    .stock-qty.out { color: var(--mp-danger); }
    .stock-link { font-size: 12px; }

    .promo-card { position: relative; overflow: hidden; border-radius: var(--mp-radius-lg); background: linear-gradient(135deg, var(--mp-primary) 0%, var(--mp-primary-dark) 100%); color: #fff; padding: var(--mp-space-6); }
    .promo-deco { position: absolute; top: -40px; right: -40px; width: 140px; height: 140px; border-radius: 999px; background: rgba(255,255,255,0.10); }
    .promo-content { position: relative; }
    .promo-emoji { font-size: 1.5rem; }
    .promo-title { color: #fff; margin: var(--mp-space-2) 0 var(--mp-space-1) 0; font-size: 18px; }
    .promo-text { font-size: 13px; color: rgba(255,255,255,0.9); margin: 0 0 var(--mp-space-4) 0; }
    .promo-btn { appearance: none; cursor: pointer; border: none; background-color: #fff; color: var(--mp-primary-dark); font-weight: 600; font-size: 14px; padding: 8px 16px; border-radius: var(--mp-radius-md); }
    .promo-btn:hover { background-color: var(--mp-primary-light); }

    .recent-table a { font-size: 13px; }

    /* Commandes récentes en liste propre (rangées sans cartes-dans-carte) */
    .recent-list { gap: 0; }
    .recent-list .mp-list-row { border: none; box-shadow: none; border-radius: 0; background: transparent; padding: var(--mp-space-3) 0; border-bottom: 1px solid var(--mp-border); text-decoration: none; }
    .recent-list .mp-list-row:last-child { border-bottom: none; }
    .recent-list .mp-list-row:hover { background: var(--mp-surface-2); text-decoration: none; }
    .recent-list .mp-list-title { color: var(--mp-primary); }
    .home-header-txt .mp-pill { margin-top: 6px; }

    @@media (max-width: 900px) {
        .home-grid { grid-template-columns: 1fr; }
    }

    /* Mobile : KPIs en grille 2×2 compacte (comme la maquette), textes réduits. */
    @@media (max-width: 640.98px) {
        .home-header { margin-bottom: var(--mp-space-4); }
        .home-header h1 { font-size: 22px; }
        .kpi-grid { grid-template-columns: 1fr 1fr; gap: var(--mp-space-2); }
        .kpi-card { padding: var(--mp-space-3); }
        .kpi-ico { width: 2.25rem; height: 2.25rem; }
        .kpi-label { font-size: 12px; }
        .kpi-value { font-size: 18px; }

        /* Les deux boutons d'action sur une seule ligne (largeurs égales). */
        .home-header-actions { flex-wrap: nowrap; width: 100%; gap: var(--mp-space-2); }
        .home-header-actions .mp-btn { flex: 1; min-width: 0; justify-content: center; padding-left: var(--mp-space-3); padding-right: var(--mp-space-3); }
    }
</style>

@code {
    private SellerDashboardKpis? kpis;
    private IReadOnlyList<SellerOrder>? orders;
    private List<Product> lowStock = new();
    private string? loadError;

    // Série 7 jours dérivée des commandes (libellés + montants).
    private string[] chartLabels = Array.Empty<string>();
    private int[] chartData = Array.Empty<int>();
    private bool chartDirty; // vrai quand de nouvelles données doivent être rendues

    private string DisplayName => string.IsNullOrEmpty(Auth.SellerName) ? "vendeur" : Auth.SellerName!;

    protected override Task OnInitializedAsync() => Reload();

    private async Task Reload()
    {
        loadError = null;
        kpis = null;
        try
        {
            kpis = await Api.GetDashboardAsync();
            orders = await Api.ListOrdersAsync();

            // Stock critique : produits en stock faible / rupture, triés du plus urgent au moins.
            try
            {
                var products = await Api.ListProductsAsync();

                // Le stock brut de la liste est à 0 : on l'enrichit depuis l'inventaire
                // (somme des disponibilités par SKU de variante), comme la page Produits,
                // sinon TOUT apparaît à tort en « rupture ».
                foreach (var p in products)
                {
                    var total = 0;
                    foreach (var sku in p.Variants.Select(v => v.Sku).Where(s => !string.IsNullOrWhiteSpace(s)).Distinct())
                    {
                        try { total += (await Api.ListInventoryBySkuAsync(sku)).Sum(i => i.Available); }
                        catch { /* SKU sans stock : ignoré */ }
                    }
                    p.Stock = total;
                }

                lowStock = products
                    .Where(p => p.StockStatus == StockStatus.LowStock || p.StockStatus == StockStatus.OutOfStock)
                    .OrderBy(p => p.Stock)
                    .Take(5)
                    .ToList();
            }
            catch { lowStock = new(); } // le stock critique est secondaire : ne bloque pas le tableau de bord

            BuildSalesSeries();
            chartDirty = true;
        }
        catch (Exception ex) { loadError = ex.Message; }
    }

    /// <summary>
    /// Construit la série des 7 derniers jours à partir des commandes.
    /// Repli : si aucune date exploitable, la série reste à 0 (le graphe ne plante pas).
    /// </summary>
    private void BuildSalesSeries()
    {
        var labels = new string[7];
        var data = new int[7];
        var frCulture = new CultureInfo("fr-FR");
        var today = DateTime.Now.Date;

        for (int i = 0; i < 7; i++)
        {
            var day = today.AddDays(-(6 - i));
            labels[i] = day.ToString("ddd", frCulture); // ex. "lun."
        }

        if (orders is not null)
        {
            foreach (var o in orders)
            {
                var d = o.Date.ToLocalTime().Date;
                var offset = (today - d).Days; // 0 = aujourd'hui, 6 = il y a 6 jours
                if (offset >= 0 && offset <= 6)
                {
                    var idx = 6 - offset;
                    data[idx] += o.TotalXof;
                }
            }
        }

        chartLabels = labels;
        chartData = data;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Rend le graphique une fois les données prêtes et le <canvas> présent dans le DOM.
        if (chartDirty && kpis is not null && loadError is null)
        {
            chartDirty = false;
            try
            {
                await JS.InvokeVoidAsync("hbaCharts.renderSalesLine", "salesLineChart", chartLabels, chartData);
            }
            catch { /* Chart.js indisponible : le tableau de bord reste fonctionnel sans le graphe. */ }
        }
    }
}
