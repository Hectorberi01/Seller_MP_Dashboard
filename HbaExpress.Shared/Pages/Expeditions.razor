@page "/expeditions"
@inject ISellerApi Api
@inject Seller_MP_Dashboard.Services.ToastService Toast

<PageTitle>Expéditions — Espace Vendeur</PageTitle>

<PageHeader Title="Expéditions"
            Subtitle="Préparez, expédiez et suivez les colis de vos commandes." />

@if (loadError is not null)
{
    <ErrorNotice Title="Expéditions indisponibles" Message="@loadError" OnRetry="Reload" />
}
else if (shipments is null)
{
    <p class="mp-caption">Chargement…</p>
}
else if (shipments.Count == 0)
{
    <MpCard>
        <ChildContent>
            <div class="empty">
                <span class="empty-ico"><AppIcon Name="package" Size="40" /></span>
                <h2 class="empty-title">Aucune expédition</h2>
                <p class="empty-sub">Les colis de vos commandes apparaîtront ici dès qu'une commande sera à préparer.</p>
            </div>
        </ChildContent>
    </MpCard>
}
else
{
    <div class="exp-toolbar">
        <input class="mp-input exp-search" placeholder="Rechercher une commande, un transporteur ou un n° de suivi…"
               value="@search" @oninput="OnSearchChanged" />
        <div class="exp-filters">
            @foreach (var f in _filters)
            {
                <button type="button" class="exp-chip @(statusFilter == f.Key ? "active" : "")"
                        @onclick="() => SetFilter(f.Key)">@f.Label</button>
            }
        </div>
        <span class="mp-caption exp-count">@Filtered.Count expédition@(Filtered.Count > 1 ? "s" : "")</span>
    </div>

    @if (Filtered.Count == 0)
    {
        <div class="exp-empty">
            <div class="exp-empty-ico"><AppIcon Name="package" Size="40" StrokeWidth="1.5" /></div>
            <p class="mp-body-strong">Aucune expédition</p>
            <p class="mp-caption">Aucune expédition ne correspond à votre recherche.</p>
        </div>
    }
    else
    {
    <MpCard NoPadding="true">
        <ChildContent>
            <table class="mp-table stack-mobile">
                <thead>
                    <tr>
                        <th>Commande</th>
                        <th>Client</th>
                        <th class="num">Articles</th>
                        <th>Transporteur</th>
                        <th>Suivi</th>
                        <th>Statut</th>
                        <th class="actions-col">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in Paged)
                    {
                        <tr>
                            <td class="mp-num cell-strong st-title">@s.OrderReference</td>
                            <td data-label="Client">@s.Customer</td>
                            <td class="num mp-num" data-label="Articles">@s.ItemCount</td>
                            <td data-label="Transporteur">@(s.Carrier ?? "—")</td>
                            <td class="mp-num" data-label="Suivi">@(s.TrackingNumber ?? "—")</td>
                            <td data-label="Statut">@ShipmentBadge(s.Status)</td>
                            <td class="actions-col st-actions">@Actions(s)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </ChildContent>
    </MpCard>

    @if (PageCount > 1)
    {
        <div class="exp-pager">
            <button class="exp-page-btn" type="button" disabled="@(_page <= 1)" @onclick="Prev">Précédent</button>
            <span class="mp-caption">Page @_page / @PageCount</span>
            <button class="exp-page-btn" type="button" disabled="@(_page >= PageCount)" @onclick="Next">Suivant</button>
        </div>
    }
    }
}

@* ---------- Modale « Expédier le colis » ---------- *@
<MpModal @bind-Visible="_showShip" Title="Expédier le colis">
    <ChildContent>
        <div class="form">
            @if (_shipTarget is not null)
            {
                <p class="ship-lead">
                    Commande <strong>@_shipTarget.OrderReference</strong> — @_shipTarget.Customer
                    (@_shipTarget.ItemCount article@(_shipTarget.ItemCount > 1 ? "s" : ""))
                </p>
            }
            <div class="field">
                <label>Transporteur</label>
                <select class="mp-input" @bind="_carrier">
                    @foreach (var c in Carriers)
                    {
                        <option value="@c">@c</option>
                    }
                </select>
            </div>
            <div class="field">
                <label>N° de suivi</label>
                <input class="mp-input" @bind="_tracking" @bind:event="oninput"
                       placeholder="Ex. 1Z999AA10123456784" />
            </div>
            @if (_shipError is not null)
            {
                <p class="loc-error">@_shipError</p>
            }
        </div>
    </ChildContent>
    <Footer>
        <MpButton Variant="ButtonVariant.Secondary" OnClick="@(() => _showShip = false)" Disabled="@_shipping">Annuler</MpButton>
        <MpButton Variant="ButtonVariant.Primary" OnClick="ConfirmShip" Disabled="@_shipping">
            @(_shipping ? "Expédition…" : "Confirmer l'expédition")
        </MpButton>
    </Footer>
</MpModal>

@* ---------- Modale « Annuler l'expédition » ---------- *@
<MpModal @bind-Visible="_showCancel" Title="Annuler l'expédition">
    <ChildContent>
        <div class="form">
            @if (_cancelTarget is not null)
            {
                <p class="ship-lead">
                    Voulez-vous annuler l'expédition de la commande
                    <strong>@_cancelTarget.OrderReference</strong> (@_cancelTarget.Customer) ?
                    Cette action ne peut pas être annulée.
                </p>
            }
            @if (_cancelError is not null)
            {
                <p class="loc-error">@_cancelError</p>
            }
        </div>
    </ChildContent>
    <Footer>
        <MpButton Variant="ButtonVariant.Secondary" OnClick="@(() => _showCancel = false)" Disabled="@_cancelling">Retour</MpButton>
        <MpButton Variant="ButtonVariant.Danger" OnClick="ConfirmCancel" Disabled="@_cancelling">
            @(_cancelling ? "Annulation…" : "Annuler l'expédition")
        </MpButton>
    </Footer>
</MpModal>

<style>
    .cell-strong { font-weight: 500; }

    .exp-toolbar { display: flex; align-items: center; gap: var(--mp-space-4); flex-wrap: wrap; margin-bottom: var(--mp-space-4); }
    .exp-search { flex: 1 1 300px; max-width: 420px; }
    .exp-filters { display: flex; gap: var(--mp-space-2); flex-wrap: wrap; }
    .exp-chip { border: 0.5px solid var(--mp-border); background-color: var(--mp-surface); border-radius: 999px; padding: 5px 14px; font-size: 13px; cursor: pointer; color: var(--mp-text); transition: all .15s ease; }
    .exp-chip:hover { border-color: var(--mp-primary); color: var(--mp-primary); }
    .exp-chip.active { background-color: var(--mp-primary); border-color: var(--mp-primary); color: #fff; }
    .exp-count { margin-left: auto; }
    .exp-empty { text-align: center; padding: var(--mp-space-8) var(--mp-space-4); border: 1px dashed var(--mp-border); border-radius: var(--mp-radius-lg); display: flex; flex-direction: column; gap: var(--mp-space-2); align-items: center; }
    .exp-empty-ico { color: var(--mp-text-muted); }
    .exp-pager { display: flex; align-items: center; justify-content: center; gap: var(--mp-space-4); margin-top: var(--mp-space-4); }
    .exp-page-btn { border: 0.5px solid var(--mp-border); background: var(--mp-surface); border-radius: var(--mp-radius-md); padding: 6px 16px; font-size: 13px; cursor: pointer; color: var(--mp-text); }
    .exp-page-btn:hover:not(:disabled) { border-color: var(--mp-primary); color: var(--mp-primary); }
    .exp-page-btn:disabled { opacity: .5; cursor: default; }

    .empty { display: flex; flex-direction: column; align-items: center; text-align: center; gap: var(--mp-space-2); padding: var(--mp-space-5) var(--mp-space-4); }
    .empty-ico {
        display: flex; align-items: center; justify-content: center;
        width: 72px; height: 72px; border-radius: var(--mp-radius-xl);
        background: var(--mp-bg); border: 1px solid var(--mp-border);
        color: var(--mp-text-muted); margin-bottom: var(--mp-space-2);
    }
    .empty-title { margin: 0; font-size: 18px; font-weight: 600; }
    .empty-sub { margin: 0; max-width: 420px; color: var(--mp-text-muted); font-size: 14px; line-height: 1.5; }

    .row-actions { display: inline-flex; gap: var(--mp-space-2); justify-content: flex-end; }

    .form { display: flex; flex-direction: column; gap: var(--mp-space-3); }
    .field { display: flex; flex-direction: column; gap: var(--mp-space-1); }
    .field label { font-size: 14px; font-weight: 500; }
    .ship-lead { margin: 0; font-size: 14px; color: var(--mp-text-muted); line-height: 1.5; }
    .mp-input {
        font-family: var(--mp-font-sans); font-size: 15px;
        padding: 10px 12px; border: 1px solid var(--mp-border);
        border-radius: var(--mp-radius-md); background-color: var(--mp-surface);
        color: var(--mp-text); resize: vertical; width: 100%;
    }
    .mp-input:focus { outline: none; border-color: var(--mp-primary); }
    .loc-error { color: var(--mp-danger); font-size: 13px; margin: 0; }
</style>

@code {
    private IReadOnlyList<Shipment>? shipments;
    private string? loadError;

    // Recherche / filtre / pagination (côté client).
    private string search = "";
    private string statusFilter = "all";
    private int _page = 1;
    private const int PageSize = 15;

    private readonly (string Key, string Label)[] _filters =
    {
        ("all", "Toutes"),
        ("todo", "À préparer"),
        ("shipped", "Expédiées"),
        ("delivered", "Livrées"),
        ("cancelled", "Annulées"),
    };

    private void SetFilter(string key) { statusFilter = key; _page = 1; }
    private void OnSearchChanged(ChangeEventArgs e) { search = e.Value?.ToString() ?? ""; _page = 1; }
    private void Prev() { if (_page > 1) _page--; }
    private void Next() { if (_page < PageCount) _page++; }

    private List<Shipment> Filtered
    {
        get
        {
            if (shipments is null) return new();
            IEnumerable<Shipment> q = shipments;

            q = statusFilter switch
            {
                "todo" => q.Where(s => s.Status is ShipmentStatus.Pending or ShipmentStatus.Prepared),
                "shipped" => q.Where(s => s.Status == ShipmentStatus.Shipped),
                "delivered" => q.Where(s => s.Status == ShipmentStatus.Delivered),
                "cancelled" => q.Where(s => s.Status == ShipmentStatus.Cancelled),
                _ => q,
            };

            if (!string.IsNullOrWhiteSpace(search))
            {
                var s = search.Trim();
                q = q.Where(x => (x.OrderReference ?? "").Contains(s, StringComparison.OrdinalIgnoreCase)
                              || (x.Customer ?? "").Contains(s, StringComparison.OrdinalIgnoreCase)
                              || (x.Carrier ?? "").Contains(s, StringComparison.OrdinalIgnoreCase)
                              || (x.TrackingNumber ?? "").Contains(s, StringComparison.OrdinalIgnoreCase));
            }
            return q.ToList();
        }
    }

    private int PageCount => Math.Max(1, (int)Math.Ceiling(Filtered.Count / (double)PageSize));
    private IEnumerable<Shipment> Paged => Filtered.Skip((Math.Min(_page, PageCount) - 1) * PageSize).Take(PageSize);

    // Transporteurs proposés dans la modale d'expédition.
    private static readonly string[] Carriers =
        { "DHL", "Chronopost", "Colissimo", "UPS", "FedEx", "La Poste", "Aramex", "Autre" };

    // État — modale d'expédition
    private bool _showShip;
    private bool _shipping;
    private Shipment? _shipTarget;
    private string _carrier = Carriers[0];
    private string _tracking = "";
    private string? _shipError;

    // État — modale d'annulation
    private bool _showCancel;
    private bool _cancelling;
    private Shipment? _cancelTarget;
    private string? _cancelError;

    protected override async Task OnInitializedAsync() => await Reload();

    private async Task Reload()
    {
        try
        {
            loadError = null;
            shipments = await Api.ListShipmentsAsync();
            if (_page > PageCount) _page = PageCount;
        }
        catch
        {
            loadError = "Impossible de joindre le serveur (BFF injoignable ou session expirée).";
        }
    }

    private RenderFragment ShipmentBadge(ShipmentStatus status) => status switch
    {
        ShipmentStatus.Pending   => @<MpBadge Variant="BadgeVariant.Promo" Icon="●">À préparer</MpBadge>,
        ShipmentStatus.Prepared  => @<MpBadge Variant="BadgeVariant.Verified" Icon="●">Préparée</MpBadge>,
        ShipmentStatus.Shipped   => @<MpBadge Variant="BadgeVariant.Verified" Icon="●">Expédiée</MpBadge>,
        ShipmentStatus.Delivered => @<MpBadge Variant="BadgeVariant.Stock" Icon="●">Livrée</MpBadge>,
        _                        => @<MpBadge Variant="BadgeVariant.Rupture" Icon="●">Annulée</MpBadge>
    };

    private RenderFragment Actions(Shipment s) => s.Status switch
    {
        ShipmentStatus.Pending  => @<div class="row-actions">
            <MpButton Variant="ButtonVariant.Primary" Icon="package" OnClick="@(() => Prepare(s))">Préparer</MpButton>
            <MpButton Variant="ButtonVariant.Danger" Icon="x" OnClick="@(() => OpenCancel(s))">Annuler</MpButton>
        </div>,
        ShipmentStatus.Prepared => @<div class="row-actions">
            <MpButton Variant="ButtonVariant.Primary" OnClick="@(() => OpenShip(s))">
                <span class="mp-btn-icon" aria-hidden="true">@TruckIcon</span>Expédier
            </MpButton>
            <MpButton Variant="ButtonVariant.Danger" Icon="x" OnClick="@(() => OpenCancel(s))">Annuler</MpButton>
        </div>,
        ShipmentStatus.Shipped  => @<div class="row-actions">
            <MpButton Variant="ButtonVariant.Action" Icon="check" OnClick="@(() => Deliver(s))">Marquer livrée</MpButton>
        </div>,
        _                       => @<MpButton Variant="ButtonVariant.Tertiary" Icon="receipt">Détails</MpButton>
    };

    // Icône camion en SVG inline (absente d'AppIcon, style Lucide, hérite de currentColor).
    private static readonly RenderFragment TruckIcon = @<svg viewBox="0 0 24 24" width="16" height="16" fill="none"
        stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2" />
        <path d="M14 9h4l4 4v4a1 1 0 0 1-1 1h-2" />
        <circle cx="7" cy="18" r="2" /><circle cx="17" cy="18" r="2" />
        <path d="M9 18h6" />
    </svg>;

    // ---------- Préparer ----------
    private async Task Prepare(Shipment s) { await Api.PrepareAsync(s.Id); await Reload(); }

    // ---------- Expédier (modale) ----------
    private void OpenShip(Shipment s)
    {
        _shipTarget = s;
        _carrier = string.IsNullOrWhiteSpace(s.Carrier) ? Carriers[0] : s.Carrier!;
        _tracking = s.TrackingNumber ?? "";
        _shipError = null;
        _showShip = true;
    }

    private async Task ConfirmShip()
    {
        _shipError = null;
        var carrier = _carrier?.Trim() ?? "";
        var tracking = _tracking?.Trim() ?? "";

        if (string.IsNullOrWhiteSpace(carrier))
        {
            _shipError = "Veuillez sélectionner un transporteur.";
            return;
        }
        if (string.IsNullOrWhiteSpace(tracking))
        {
            _shipError = "Le numéro de suivi est obligatoire.";
            return;
        }
        if (_shipTarget is null) { _showShip = false; return; }

        try
        {
            _shipping = true;
            await Api.ShipAsync(_shipTarget.Id, new ShipRequest(carrier, tracking));
            _showShip = false;
            await Reload();
            await Toast.Success("Colis marqué comme expédié 🚚");
            await Toast.Celebrate();
        }
        catch
        {
            _shipError = "L'expédition a échoué. Vérifiez la connexion puis réessayez.";
            await Toast.Error("L'expédition a échoué. Réessayez.");
        }
        finally
        {
            _shipping = false;
        }
    }

    // ---------- Livrer ----------
    private async Task Deliver(Shipment s) { await Api.DeliverAsync(s.Id); await Reload(); }

    // ---------- Annuler (modale de confirmation) ----------
    private void OpenCancel(Shipment s)
    {
        _cancelTarget = s;
        _cancelError = null;
        _showCancel = true;
    }

    private async Task ConfirmCancel()
    {
        if (_cancelTarget is null) { _showCancel = false; return; }
        try
        {
            _cancelling = true;
            await Api.CancelAsync(_cancelTarget.Id);
            _showCancel = false;
            await Reload();
        }
        catch
        {
            _cancelError = "L'annulation a échoué. Vérifiez la connexion puis réessayez.";
        }
        finally
        {
            _cancelling = false;
        }
    }
}
