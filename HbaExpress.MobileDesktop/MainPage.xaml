<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:b="clr-namespace:Microsoft.AspNetCore.Components.WebView.Maui;assembly=Microsoft.AspNetCore.Components.WebView.Maui"
             xmlns:shared="clr-namespace:Seller_MP_Dashboard;assembly=HbaExpress.Shared"
             x:Class="HbaExpress.MobileDesktop.MainPage"
             BackgroundColor="#F8FAF8">

    <b:BlazorWebView x:Name="blazorWebView" HostPage="wwwroot/index.html">
        <b:BlazorWebView.RootComponents>
            <!-- On réutilise le routeur partagé App (RCL HbaExpress.Shared). -->
            <b:RootComponent Selector="#app" ComponentType="{x:Type shared:App}" />
        </b:BlazorWebView.RootComponents>
    </b:BlazorWebView>

</ContentPage>
