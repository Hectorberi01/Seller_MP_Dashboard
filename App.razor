<Router AppAssembly="@typeof(App).Assembly">
    <Found Context="routeData">
        <RouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)"/>
        <FocusOnNavigate RouteData="@routeData" Selector="h1"/>
    </Found>
    <NotFound>
        <PageTitle>Page introuvable — Espace Vendeur</PageTitle>
        @* BlankLayout (pas MainLayout) : MainLayout redirige vers /login si non
           authentifié, ce qui masquerait le 404. La vue s'affiche donc pour tous. *@
        <LayoutView Layout="@typeof(BlankLayout)">
            <NotFoundView />
        </LayoutView>
    </NotFound>
</Router>