@* Icône SVG line monochrome (style Lucide). Hérite de la couleur via currentColor. *@

@if (Path is not null)
{
    <svg viewBox="0 0 24 24" width="@Size" height="@Size" fill="none" stroke="currentColor"
         stroke-width="@Width" stroke-linecap="round" stroke-linejoin="round"
         class="app-icon" aria-hidden="true">
        @((MarkupString)Path)
    </svg>
}
else
{
    @Name
}

@code {
    [Parameter] public string? Name { get; set; }
    [Parameter] public int Size { get; set; } = 18;
    [Parameter] public string? StrokeWidth { get; set; }

    private string Width => StrokeWidth ?? "1.8";

    // Paths Lucide (chemins internes du <svg>, viewBox 0 0 24 24).
    private string? Path => Name switch
    {
        "edit" or "pencil" => "<path d=\"M12 20h9\"/><path d=\"M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z\"/>",
