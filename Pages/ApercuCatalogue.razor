@page "/apercu-catalogue"
@inject ISellerApi Api

<PageTitle>Aperçu du catalogue — Espace Vendeur</PageTitle>

<PageHeader Title="Aperçu du catalogue"
            Subtitle="Votre vitrine telle que les acheteurs la voient." />

@if (loadError is not null)
{
    <ErrorNotice Title="Catalogue indisponible" Message="@loadError" OnRetry="Load" />
}
else if (products is null)
{
    <p class="mp-caption">Chargement…</p>
}
else
{
    <div class="cat-toolbar">
        <input class="mp-input cat-search" placeholder="Rechercher un produit…" value="@search" @oninput="OnSearchChanged" />
        <div class="cat-filters">
            @foreach (var f in _filters)
            {
                <button type="button" class="cat-chip @(statusFilter == f.Key ? "active" : "")"
                        @onclick="() => SetFilter(f.Key)">@f.Label</button>
            }
        </div>
        <span class="mp-caption cat-count">@Filtered.Count produit@(Filtered.Count > 1 ? "s" : "")</span>
    </div>

    @if (Filtered.Count == 0)
    {
        <div class="cat-empty">
            <div class="cat-empty-ico"><AppIcon Name="package" Size="40" StrokeWidth="1.5" /></div>
            <p class="mp-body-strong">Aucun produit à afficher</p>
            <p class="mp-caption">Ajoutez des produits depuis la page « Produits » pour les voir apparaître ici.</p>
        </div>
    }
    else
    {
        <div class="cat-grid">
            @foreach (var p in Paged)
            {
                <a class="cat-card" href="produit/@p.Id">
                    <div class="cat-thumb">
                        @if (!string.IsNullOrEmpty(p.PrimaryImage?.Url))
                        {
                            <img src="@p.PrimaryImage!.Url" alt="@p.Name" />
                        }
                        else
                        {
                            <span class="cat-thumb-emoji">@p.Emoji</span>
                        }
                        @if (p.DiscountPercent is int d)
                        {
                            <span class="cat-badge-promo">-@d%</span>
                        }
                        @if (p.Status != "Active")
                        {
                            <span class="cat-badge-status">@StatusLabel(p.Status)</span>
                        }
                    </div>
                    <div class="cat-body">
                        <span class="cat-name">@p.Name</span>
                        <div class="cat-price-row">
                            <span class="cat-price">@Format.Xof(p.PriceXof)</span>
                            @if (p.OldPriceXof is int op && op > p.PriceXof)
                            {
                                <span class="cat-oldprice">@Format.Xof(op)</span>
                            }
                        </div>
                        <div class="cat-meta">
                            @if (p.ReviewCount > 0)
                            {
                                <span class="cat-rating">★ @p.Rating.ToString("0.0") <span class="mp-caption">(@p.ReviewCount)</span></span>
                            }
                            <StockBadge Status="p.StockStatus" Stock="p.Stock" />
                        </div>
                    </div>
                </a>
            }
        </div>

        @if (PageCount > 1)
        {
            <div class="cat-pager">
                <button class="cat-page-btn" type="button" disabled="@(_page <= 1)" @onclick="PrevP">Précédent</button>
                <span class="mp-caption">Page @_page / @PageCount</span>
                <button class="cat-page-btn" type="button" disabled="@(_page >= PageCount)" @onclick="NextP">Suivant</button>
            </div>
        }
    }
}

<style>
    .cat-pager { display: flex; align-items: center; justify-content: center; gap: var(--mp-space-4); margin-top: var(--mp-space-5); }
    .cat-page-btn { border: 0.5px solid var(--mp-border); background: var(--mp-surface); border-radius: var(--mp-radius-md); padding: 6px 16px; font-size: 13px; cursor: pointer; color: var(--mp-text); }
    .cat-page-btn:hover:not(:disabled) { border-color: var(--mp-primary); color: var(--mp-primary); }
    .cat-page-btn:disabled { opacity: .5; cursor: default; }
    .cat-toolbar {
        display: flex; align-items: center; gap: var(--mp-space-4);
        flex-wrap: wrap; margin-bottom: var(--mp-space-4);
    }
    .cat-search { flex: 1 1 260px; max-width: 360px; }
    .cat-filters { display: flex; gap: var(--mp-space-2); flex-wrap: wrap; }
    .cat-chip {
        border: 0.5px solid var(--mp-border); background-color: var(--mp-surface);
        border-radius: 999px; padding: 5px 14px; font-size: 13px; cursor: pointer; color: var(--mp-text);
        transition: all .15s ease;
    }
    .cat-chip:hover { border-color: var(--mp-primary); color: var(--mp-primary); }
    .cat-chip.active { background-color: var(--mp-primary); border-color: var(--mp-primary); color: #fff; }
    .cat-count { margin-left: auto; }

    .cat-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: var(--mp-space-4);
    }
    .cat-card {
        display: flex; flex-direction: column;
        background-color: var(--mp-surface);
        border: 0.5px solid var(--mp-border);
        border-radius: var(--mp-radius-lg);
        overflow: hidden; text-decoration: none; color: inherit;
        transition: box-shadow .15s ease, transform .15s ease, border-color .15s ease;
    }
    .cat-card:hover {
        box-shadow: 0 6px 20px rgba(4, 44, 83, 0.10);
        border-color: var(--mp-primary-400);
        transform: translateY(-2px);
        text-decoration: none;
    }
    .cat-thumb {
        position: relative; aspect-ratio: 1 / 1; background-color: var(--mp-surface-2);
        display: flex; align-items: center; justify-content: center; overflow: hidden;
    }
    .cat-thumb img { width: 100%; height: 100%; object-fit: cover; }
    .cat-thumb-emoji { font-size: 54px; }
    .cat-badge-promo {
        position: absolute; top: 8px; left: 8px;
        background-color: var(--mp-danger); color: #fff;
        font-size: 12px; font-weight: 700; border-radius: 6px; padding: 2px 7px;
    }
    .cat-badge-status {
        position: absolute; top: 8px; right: 8px;
        background-color: rgba(4, 44, 83, 0.82); color: #fff;
        font-size: 11px; font-weight: 600; border-radius: 6px; padding: 2px 7px;
    }
    .cat-body { padding: var(--mp-space-3); display: flex; flex-direction: column; gap: var(--mp-space-2); }
    .cat-name {
        font-weight: 600; color: var(--mp-primary-dark); line-height: 1.25;
        display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
        min-height: 2.5em;
    }
    .cat-price-row { display: flex; align-items: baseline; gap: var(--mp-space-2); }
    .cat-price { font-size: 17px; font-weight: 700; color: var(--mp-text); }
    .cat-oldprice { font-size: 13px; color: var(--mp-text-muted); text-decoration: line-through; }
    .cat-meta { display: flex; align-items: center; justify-content: space-between; gap: var(--mp-space-2); }
    .cat-rating { font-size: 13px; color: #E8A33D; font-weight: 600; }

    .cat-empty {
        text-align: center; padding: var(--mp-space-8) var(--mp-space-4);
        border: 1px dashed var(--mp-border); border-radius: var(--mp-radius-lg);
        display: flex; flex-direction: column; gap: var(--mp-space-2); align-items: center;
    }
    .cat-empty-ico { font-size: 40px; }
</style>

@code {
    private List<Product>? products;
    private string? loadError;
    private string search = "";
    private string statusFilter = "all";
    private int _page = 1;
    private const int PageSize = 24;

    private int PageCount => Math.Max(1, (int)Math.Ceiling(Filtered.Count / (double)PageSize));
    private List<Product> Paged => Filtered.Skip((Math.Min(_page, PageCount) - 1) * PageSize).Take(PageSize).ToList();

    private void SetFilter(string key) { statusFilter = key; _page = 1; }
    private void OnSearchChanged(ChangeEventArgs e) { search = e.Value?.ToString() ?? ""; _page = 1; }
    private void PrevP() { if (_page > 1) _page--; }
    private void NextP() { if (_page < PageCount) _page++; }

    private readonly (string Key, string Label)[] _filters =
    {
        ("all", "Tous"),
        ("Active", "Actifs"),
        ("Draft", "Brouillons"),
        ("Archived", "Archivés"),
    };

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        loadError = null;
        try
        {
            products = (await Api.ListProductsAsync()).ToList();
            await EnrichPricesAndStock();
        }
        catch (Exception ex)
        {
            loadError = ex.Message;
        }
    }

    // La vitrine acheteur doit refléter le prix réel (meilleure offre) et le stock
    // réel (inventaire), comme la page Produits — sinon tout s'affiche à 0 / Rupture.
    private async Task EnrichPricesAndStock()
    {
        if (products is null) return;

        // Prix : meilleure offre (la moins chère) par produit.
        try
        {
            var byProduct = (await Api.ListOffersAsync())
                .GroupBy(o => o.ProductId)
                .ToDictionary(g => g.Key, g => g.OrderBy(o => o.BasePriceAmount).First());
            foreach (var p in products)
            {
                if (byProduct.TryGetValue(p.Id, out var best))
                {
                    p.PriceXof = (int)Math.Round(best.BasePriceAmount);
                }
            }
        }
        catch { /* prix optionnel */ }

        // Stock : somme des disponibilités des variantes (par SKU).
        foreach (var p in products)
        {
            var total = 0;
            foreach (var sku in p.Variants.Select(v => v.Sku).Where(s => !string.IsNullOrWhiteSpace(s)).Distinct())
            {
                try { total += (await Api.ListInventoryBySkuAsync(sku)).Sum(i => i.Available); }
                catch { /* SKU sans stock : ignoré */ }
            }
            p.Stock = total;
        }

        StateHasChanged();
    }

    private List<Product> Filtered
    {
        get
        {
            if (products is null) return new();
            IEnumerable<Product> q = products;
            if (statusFilter != "all")
            {
                q = q.Where(p => string.Equals(p.Status, statusFilter, StringComparison.OrdinalIgnoreCase));
            }
            if (!string.IsNullOrWhiteSpace(search))
            {
                var s = search.Trim();
                q = q.Where(p => p.Name.Contains(s, StringComparison.OrdinalIgnoreCase)
                              || p.Sku.Contains(s, StringComparison.OrdinalIgnoreCase));
            }
            return q.ToList();
        }
    }

    private static string StatusLabel(string s) => s switch
    {
        "Draft" => "Brouillon",
        "Archived" => "Archivé",
        "Active" => "Actif",
        _ => s
    };
}
