@page "/produit/{Id:guid}/apercu"
@using Seller_MP_Dashboard.Api
@inject ISellerApi Api
@inject NavigationManager Nav

<PageTitle>Aperçu — @(product?.Name ?? "Produit")</PageTitle>

<div class="preview-bar">
    <span class="preview-tag"><AppIcon Name="eye" Size="16" /> Aperçu client</span>
    <span class="preview-hint mp-caption">Voici comment votre produit apparaîtra aux acheteurs.</span>
    <MpButton Variant="ButtonVariant.Secondary" OnClick="@(() => Nav.NavigateTo($"produit/{Id}"))">← Retour à la fiche</MpButton>
</div>

@if (_loading)
{
    <p class="mp-caption">Chargement…</p>
}
else if (product is null)
{
    <p class="mp-caption">Produit introuvable.</p>
}
else
{
    <div class="shop-frame">
        <div class="pdp">
            <div class="pdp-gallery">
                <div class="pdp-main">
                    @if (!string.IsNullOrEmpty(CurrentImage?.Url))
                    {
                        <img src="@CurrentImage!.Url" alt="@(CurrentImage.AltText ?? product.Name)" />
                    }
                    else
                    {
                        <div class="pdp-noimg" aria-hidden="true"><AppIcon Name="package" Size="32" /></div>
                    }
                </div>
                @if (product.Images.Count > 1)
                {
                    <div class="pdp-thumbs">
                        @for (var i = 0; i < product.Images.Count; i++)
                        {
                            var idx = i;
                            var img = product.Images[i];
                            <button type="button" class="pdp-thumb @(idx == _img ? "is-active" : null)" @onclick="@(() => _img = idx)">
                                @if (!string.IsNullOrEmpty(img.Url)) { <img src="@img.Url" alt="" /> }
                            </button>
                        }
                    </div>
                }
            </div>

            <div class="pdp-info">
                <h1 class="pdp-name">@product.Name</h1>

                <div class="pdp-rating">
                    <span class="stars">@Stars(_avgRating)</span>
                    <span class="mp-caption">@(_reviews is { Count: > 0 } ? $"{_avgRating:0.0} · {_reviews.Count} avis" : "Pas encore d'avis")</span>
                </div>

                <div class="pdp-price">
                    @if (_minPrice is not null)
                    {
                        <div class="price-block">
                            <span class="price-now">@_minPrice.Value.ToString("N0") @_priceCurrency</span>
                            @if (_minSellerPrice is not null)
                            {
                                <span class="price-seller mp-caption">dont @_minSellerPrice.Value.ToString("N0") @_priceCurrency pour vous (prix vendeur)</span>
                            }
                        </div>
                        @if (_offerCount > 1) { <span class="mp-caption">à partir de · @_offerCount offres</span> }
                    }
                    else
                    {
                        <span class="price-none mp-caption">Prix bientôt disponible</span>
                    }
                </div>

                @if (!string.IsNullOrWhiteSpace(product.Description))
                {
                    <p class="pdp-desc">@product.Description</p>
                }

                @if (product.Variants.Count > 0)
                {
                    <div class="pdp-variants">
                        <span class="mp-caption">Déclinaisons</span>
                        <div class="variant-chips">
                            @foreach (var v in product.Variants)
                            {
                                <span class="variant-chip">@(string.IsNullOrWhiteSpace(v.AttributesLabel) || v.AttributesLabel == "—" ? v.Sku : v.AttributesLabel)</span>
                            }
                        </div>
                    </div>
                }

                <div class="pdp-cta">
                    <button class="btn-cart" disabled><AppIcon Name="shopping-cart" Size="16" /> Ajouter au panier</button>
                    <button class="btn-wish" disabled aria-label="Ajouter aux favoris">
                        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                    </button>
                </div>
                <p class="mp-caption pdp-soldby">Vendu par <strong>votre boutique</strong></p>
            </div>
        </div>

        @if (_allOffers.Count > 0)
        {
            <div class="pdp-offers">
                <h2>Offres disponibles (@_allOffers.Count)</h2>
                <div class="offer-cards">
                    @foreach (var o in _allOffers)
                    {
                        <div class="offer-card">
                            <div class="oc-main">
                                <span class="oc-price">@o.EffectiveProductPrice.ToString("N0") @o.Currency</span>
                                <span class="oc-seller mp-caption">dont @o.EffectiveSellerPrice.ToString("N0") @o.Currency pour vous (prix vendeur)</span>
                                <span class="oc-cond">@ConditionLabel(o.Condition)</span>
                            </div>
                            <div class="oc-meta mp-caption">
                                <span>Expédié en @o.HandlingTime jour@(o.HandlingTime > 1 ? "s" : "")</span>
                                <span>Vendu par votre boutique</span>
                            </div>
                            <button class="oc-btn" disabled>Choisir cette offre</button>
                        </div>
                    }
                </div>
            </div>
        }

        @if (_reviews is { Count: > 0 })
        {
            <div class="pdp-reviews">
                <h2>Avis clients</h2>
                @foreach (var r in _reviews)
                {
                    <div class="pdp-review">
                        <div class="pr-head"><strong>@r.Author</strong> <span class="stars sm">@Stars(r.Rating)</span></div>
                        <p>@r.Body</p>
                        @if (!string.IsNullOrWhiteSpace(r.SellerReply))
                        {
                            <p class="pr-reply"><strong>Réponse du vendeur :</strong> @r.SellerReply</p>
                        }
                    </div>
                }
            </div>
        }
    </div>
}

<style>
    .preview-bar { display: flex; align-items: center; gap: var(--mp-space-3); padding: var(--mp-space-3) var(--mp-space-4); background: #fff7e6; border: 1px solid #f0d27a; border-radius: var(--mp-radius-md); margin-bottom: var(--mp-space-4); }
    .preview-tag { font-weight: 600; display: inline-flex; align-items: center; gap: 6px; }
    .preview-hint { margin-right: auto; }

    .shop-frame { background: var(--mp-surface); border: 1px solid var(--mp-border); border-radius: var(--mp-radius-xl); padding: var(--mp-space-6); max-width: 1000px; }
    .pdp { display: grid; grid-template-columns: 440px 1fr; gap: var(--mp-space-6); align-items: start; }
    @@media (max-width: 820px) { .pdp { grid-template-columns: 1fr; } }

    .pdp-main { width: 100%; aspect-ratio: 1/1; background: var(--mp-surface-2); border-radius: var(--mp-radius-lg); overflow: hidden; display: flex; align-items: center; justify-content: center; }
    .pdp-main img { width: 100%; height: 100%; object-fit: cover; }
    .pdp-noimg { font-size: 120px; }
    .pdp-thumbs { display: flex; gap: var(--mp-space-2); margin-top: var(--mp-space-2); flex-wrap: wrap; }
    .pdp-thumb { width: 64px; height: 64px; padding: 0; border: 1px solid var(--mp-border); border-radius: var(--mp-radius-md); overflow: hidden; cursor: pointer; background: var(--mp-surface); }
    .pdp-thumb.is-active { border-color: var(--mp-primary, #1d4ed8); border-width: 2px; }
    .pdp-thumb img { width: 100%; height: 100%; object-fit: cover; }

    .pdp-info { display: flex; flex-direction: column; gap: var(--mp-space-3); }
    .pdp-name { font-size: 28px; margin: 0; }
    .pdp-rating { display: flex; align-items: center; gap: var(--mp-space-2); }
    .stars { color: var(--mp-accent, #f5a623); letter-spacing: 1px; }
    .stars.sm { font-size: 13px; }
    .pdp-price { display: flex; align-items: baseline; gap: var(--mp-space-3); flex-wrap: wrap; }
    .price-block { display: flex; flex-direction: column; gap: 2px; }
    .price-now { font-size: 30px; font-weight: 700; color: var(--mp-primary-dark, #11324d); }
    .price-seller { font-weight: 400; }
    .oc-seller { font-weight: 400; }
    .pdp-desc { color: var(--mp-text); white-space: pre-wrap; margin: 0; }
    .pdp-variants { display: flex; flex-direction: column; gap: var(--mp-space-2); }
    .variant-chips { display: flex; flex-wrap: wrap; gap: var(--mp-space-2); }
    .variant-chip { border: 1px solid var(--mp-border); border-radius: 999px; padding: 4px 12px; font-size: 13px; }
    .pdp-cta { display: flex; gap: var(--mp-space-2); margin-top: var(--mp-space-2); }
    .btn-cart { flex: 1; display: inline-flex; align-items: center; justify-content: center; gap: 8px; background: var(--mp-action, #1a7f37); color: #fff; border: none; border-radius: var(--mp-radius-md); padding: 14px; font-size: 16px; font-weight: 600; cursor: not-allowed; opacity: .9; }
    .btn-wish { width: 52px; display: inline-flex; align-items: center; justify-content: center; border: 1px solid var(--mp-border); border-radius: var(--mp-radius-md); background: var(--mp-surface); color: var(--mp-text-muted); cursor: not-allowed; }
    .pdp-soldby { margin: 0; }

    .pdp-offers { margin-top: var(--mp-space-6); border-top: 1px solid var(--mp-border); padding-top: var(--mp-space-4); }
    .pdp-offers h2 { font-size: 20px; }
    .offer-cards { display: flex; flex-direction: column; gap: var(--mp-space-2); }
    .offer-card { display: flex; align-items: center; gap: var(--mp-space-4); border: 1px solid var(--mp-border); border-radius: var(--mp-radius-md); padding: var(--mp-space-3) var(--mp-space-4); }
    .oc-main { display: flex; flex-direction: column; min-width: 140px; }
    .oc-price { font-size: 20px; font-weight: 700; color: var(--mp-primary-dark, #11324d); }
    .oc-cond { font-size: 13px; color: var(--mp-text-muted); }
    .oc-meta { display: flex; flex-direction: column; gap: 2px; margin-right: auto; }
    .oc-btn { background: var(--mp-action, #1a7f37); color: #fff; border: none; border-radius: var(--mp-radius-md); padding: 10px 18px; font-weight: 600; cursor: not-allowed; opacity: .9; }

    .pdp-reviews { margin-top: var(--mp-space-6); border-top: 1px solid var(--mp-border); padding-top: var(--mp-space-4); }
    .pdp-reviews h2 { font-size: 20px; }
    .pdp-review { padding: var(--mp-space-3) 0; border-bottom: 0.5px solid var(--mp-border); }
    .pr-head { display: flex; align-items: center; gap: var(--mp-space-2); }
    .pr-reply { font-size: 13px; color: var(--mp-text-muted); background: var(--mp-surface-2); padding: 8px 12px; border-radius: var(--mp-radius-md); }
</style>

@code {
    [Parameter] public Guid Id { get; set; }
    private Product? product;
    private IReadOnlyList<Review>? _reviews;
    private bool _loading = true;
    private int _img;

    private decimal? _minPrice;
    private decimal? _minSellerPrice;
    private string _priceCurrency = "";
    private int _offerCount;
    private double _avgRating;
    private List<Offer> _allOffers = new();

    protected override async Task OnParametersSetAsync()
    {
        _loading = true; _img = 0;
        try { product = await Api.GetProductDetailAsync(Id); }
        catch { product = null; }

        if (product is not null)
        {
            try
            {
                var offers = (await Api.ListOffersAsync()).Where(o => o.ProductId == Id).ToList();
                _offerCount = offers.Count;
                var active = offers.Where(o => o.Status.Equals("active", StringComparison.OrdinalIgnoreCase)).ToList();
                var pool = active.Count > 0 ? active : offers;
                // Tri sur le prix produit (payé par l'acheteur), c'est le prix affiché.
                _allOffers = pool.OrderBy(o => o.EffectiveProductPrice).ToList();
                if (_allOffers.Count > 0)
                {
                    _minPrice = (decimal)_allOffers[0].EffectiveProductPrice;
                    _minSellerPrice = (decimal)_allOffers[0].EffectiveSellerPrice;
                    _priceCurrency = _allOffers[0].Currency;
                }
            }
            catch { /* prix optionnel */ }

            try
            {
                _reviews = await Api.GetProductReviewsAsync(Id);
                _avgRating = _reviews.Count > 0 ? _reviews.Average(r => r.Rating) : 0;
            }
            catch { _reviews = Array.Empty<Review>(); }
        }

        _loading = false;
    }

    private ProductImage? CurrentImage =>
        product is not null && product.Images.Count > 0
            ? product.Images[Math.Clamp(_img, 0, product.Images.Count - 1)]
            : null;

    private static string Stars(double rating)
    {
        var full = (int)Math.Round(rating);
        return new string('★', Math.Clamp(full, 0, 5)) + new string('☆', 5 - Math.Clamp(full, 0, 5));
    }

    private static string ConditionLabel(string c) => c.ToLowerInvariant() switch
    {
        "new" => "Neuf",
        "used" => "Occasion",
        "refurbished" => "Reconditionné",
        _ => c
    };
}
