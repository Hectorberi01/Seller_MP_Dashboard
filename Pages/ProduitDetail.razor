@code {
    [Parameter] public Guid Id { get; set; }
    private Product? product;
    private bool _loading = true;
    private int selectedImage;

    private IReadOnlyList<SellerBrand>? _brands;
    private IReadOnlyList<Location>? _locations;

    // Devises depuis la configuration (wwwroot/appsettings.json), pas en dur.
    private string[] _currencies = Array.Empty<string>();

    // --- Offres & avis du produit ---
    private IReadOnlyList<Offer>? _offers;
    private IReadOnlyList<Review>? _reviews;
    private readonly Dictionary<Guid, string> _replyText = new();

    // --- Édition prix d'offre ---
    private bool _showOfferEdit;
    private Guid _offerEditId;
    private double _offerEditPrice;
    private string _offerEditCurrency = "XOF";
    private int _offerEditHandling;
    private int _offerEditHandlingInitial;
    private double _offerEditPriceInitial;
    private string _offerEditCurrencyInitial = "";
    private string? _offerEditError;

    // --- Statut produit ---
    private string? _statusError;

    // --- Gestion images ---
    private string? _mediaError;
    private string _imgAlt = "";
    private const long MaxImageBytes = 5 * 1024 * 1024;

    // --- Ajustement de stock ---
    private readonly Dictionary<Guid, int> _adjVal = new();

    // --- Ajout / édition de variante ---
    private bool _showVariant;
    private Guid? _variantEditId;
    private string? _variantError;
    private VariantForm _variant = new();

    // --- Stock / inventaire ---
    private string _stockSku = "";
    private IReadOnlyList<InventoryItem>? _stockItems;
    private string? _stockError;
    private readonly Dictionary<Guid, int> _recvQty = new();
    private readonly Dictionary<Guid, int> _thrVal = new();
    private NewStockForm _newStock = new();

    // --- Édition produit ---
    private bool _showEdit;
    private string? _editError;
    private EditForm _edit = new();

    // --- Ajout d'offre ---
    private bool _showOffer;
    private string? _offerError;
    private OfferForm _offer = new();

    protected override void OnInitialized()
    {
        // Lecture sans le binder de configuration (GetChildren suffit côté WASM).
        var configured = Config.GetSection("Offers:Currencies").GetChildren()
            .Select(c => c.Value)
            .Where(v => !string.IsNullOrWhiteSpace(v))
            .Select(v => v!)
            .ToArray();
        _currencies = configured.Length > 0 ? configured : new[] { "XOF", "EUR", "USD" };
    }

    protected override async Task OnParametersSetAsync()
    {
        selectedImage = 0;
        _loading = true;
        _offers = null; _reviews = null;
        try
        {
            product = await Api.GetProductDetailAsync(Id);
        }
        catch
        {
            product = null;
        }
        finally
        {
            _loading = false;
        }

        if (product is not null)
        {
            await ReloadOffers();
            await LoadReviews();
            try { _locations = await Api.ListLocationsAsync(); } catch { _locations = Array.Empty<Location>(); }
            _stockSku = product.Variants.FirstOrDefault()?.Sku ?? "";
            await LoadStock();
        }
    }

    // ---------- Stock ----------
    private async Task LoadStock()
    {
        _stockError = null;
        if (string.IsNullOrWhiteSpace(_stockSku)) { _stockItems = Array.Empty<InventoryItem>(); return; }
        try
        {
            _stockItems = await Api.ListInventoryBySkuAsync(_stockSku);
            foreach (var it in _stockItems)
            {
                _recvQty.TryAdd(it.Id, 1);
                _thrVal[it.Id] = it.ReorderThreshold;
                _adjVal.TryAdd(it.Id, 0);
            }
        }
        catch (Exception ex) { _stockError = ex.Message; _stockItems = Array.Empty<InventoryItem>(); }
    }

    private string LocationName(Guid locationId)
    {
        var l = _locations?.FirstOrDefault(x => x.Id == locationId);
        return l is null ? locationId.ToString()[..8] : $"{l.Line}, {l.City}";
    }

    private async Task Receive(Guid itemId)
    {
        var qty = _recvQty.TryGetValue(itemId, out var q) ? q : 0;
        if (qty <= 0) { _stockError = "Quantité à réceptionner invalide."; return; }
        try { await Api.ReceiveAsync(itemId, new QuantityRequest(qty)); await LoadStock(); }
        catch (Exception ex) { _stockError = ex.Message; }
    }

    private async Task SetThreshold(Guid itemId)
    {
        var val = _thrVal.TryGetValue(itemId, out var t) ? t : 0;
        if (val < 0) { _stockError = "Seuil invalide."; return; }
        try { await Api.SetReorderThresholdAsync(itemId, new ThresholdRequest(val)); await LoadStock(); }
        catch (Exception ex) { _stockError = ex.Message; }
    }

    private async Task Adjust(Guid itemId)
    {
        var delta = _adjVal.TryGetValue(itemId, out var d) ? d : 0;
        if (delta == 0) { _stockError = "L'ajustement ne peut pas être nul."; return; }
        try { await Api.AdjustAsync(itemId, new DeltaRequest(delta)); await LoadStock(); }
        catch (Exception ex) { _stockError = ex.Message; }
    }

    private async Task CreateStock()
    {
        _stockError = null;
        if (string.IsNullOrWhiteSpace(_stockSku)) { _stockError = "Sélectionnez une variante."; return; }
        if (!Guid.TryParse(_newStock.LocationId, out var locId)) { _stockError = "Choisissez un lieu."; return; }
        try
        {
            await Api.CreateItemAsync(new CreateInventoryItemRequest(_stockSku, locId, _newStock.OnHand, _newStock.Threshold));
            _newStock = new NewStockForm();
            await LoadStock();
        }
        catch (Exception ex) { _stockError = ex.Message; }
    }

    private async Task LoadReviews()
    {
        try { _reviews = await Api.GetProductReviewsAsync(Id); }
        catch { _reviews = Array.Empty<Review>(); }
        foreach (var r in _reviews) _replyText.TryAdd(r.Id, "");
    }

    private async Task ReloadOffers()
    {
        try
        {
            var all = await Api.ListOffersAsync();
            _offers = all.Where(o => o.ProductId == Id).ToList();
        }
        catch { _offers = Array.Empty<Offer>(); }
    }

    private async Task ReloadProduct()
    {
        try { product = await Api.GetProductDetailAsync(Id); } catch { /* garde l'état */ }
        if (selectedImage >= (product?.Images.Count ?? 0)) selectedImage = 0;
    }

    private static bool IsOfferActive(string s) => s.Equals("active", StringComparison.OrdinalIgnoreCase);

    // ---------- Offres ----------
    private void OpenEditOffer(Offer o)
    {
        _offerEditId = o.Id;
        _offerEditPrice = _offerEditPriceInitial = o.BasePriceAmount;
        _offerEditCurrency = _offerEditCurrencyInitial = o.Currency;
        _offerEditHandling = _offerEditHandlingInitial = o.HandlingTime;
        _offerEditError = null;
        _showOfferEdit = true;
    }

    private async Task SaveOfferPrice()
    {
        if (_offerEditPrice <= 0) { _offerEditError = "Le prix doit être positif."; return; }
        if (_offerEditHandling < 0) { _offerEditError = "Le délai ne peut pas être négatif."; return; }
        try
        {
            if (_offerEditPrice != _offerEditPriceInitial || _offerEditCurrency != _offerEditCurrencyInitial)
            {
                await Api.SetPriceAsync(_offerEditId, new OfferPriceRequest(_offerEditPrice, _offerEditCurrency));
            }
            if (_offerEditHandling != _offerEditHandlingInitial)
            {
                await Api.SetHandlingTimeAsync(_offerEditId, new HandlingTimeRequest(_offerEditHandling));
            }
            _showOfferEdit = false;
            await ReloadOffers();
        }
        catch (Exception ex) { _offerEditError = ex.Message; }
    }

    private async Task ToggleOffer(Offer o)
    {
        var next = IsOfferActive(o.Status) ? "Paused" : "Active";
        try { await Api.SetStatusAsync(o.Id, new OfferStatusRequest(next)); await ReloadOffers(); }
        catch { /* ignore */ }
    }

    // ---------- Avis ----------
    private async Task Reply(Guid reviewId)
    {
        if (!_replyText.TryGetValue(reviewId, out var body) || string.IsNullOrWhiteSpace(body)) return;
        try
        {
            await Api.ReplyAsync(reviewId, body.Trim());
            await LoadReviews();
        }
        catch { /* ignore */ }
    }

    // ---------- Images ----------
    private async Task OnImageSelected(InputFileChangeEventArgs e)
    {
        _mediaError = null;
        if (product is null) return;
        try
        {
            var file = e.File;
            using var ms = new MemoryStream();
            await file.OpenReadStream(MaxImageBytes).CopyToAsync(ms);
            await Api.UploadImageAsync(product.Id, new ProductImageUpload
            {
                FileName = file.Name,
                ContentType = string.IsNullOrEmpty(file.ContentType) ? "image/jpeg" : file.ContentType,
                Content = ms.ToArray(),
                AltText = string.IsNullOrWhiteSpace(_imgAlt) ? null : _imgAlt.Trim()
            });
            _imgAlt = "";
            await ReloadProduct();
        }
        catch (Exception ex) { _mediaError = $"Échec de l'ajout : {ex.Message}"; }
    }

    private async Task SetPrimary(Guid mediaId)
    {
        if (product is null) return;
        try { await Api.SetPrimaryImageAsync(product.Id, mediaId); await ReloadProduct(); }
        catch (Exception ex) { _mediaError = ex.Message; }
    }

    private async Task RemoveImage(Guid mediaId)
    {
        if (product is null) return;
        try { await Api.RemoveImageAsync(product.Id, mediaId); await ReloadProduct(); }
        catch (Exception ex) { _mediaError = ex.Message; }
    }

    private async Task MoveImage(int index, int delta)
    {
        if (product is null) return;
        var ids = product.Images.Select(i => i.Id).ToList();
        var target = index + delta;
        if (target < 0 || target >= ids.Count) return;
        (ids[index], ids[target]) = (ids[target], ids[index]);
        try { await Api.ReorderImagesAsync(product.Id, ids); await ReloadProduct(); }
        catch (Exception ex) { _mediaError = ex.Message; }
    }

    // ---------- Variantes ----------
    private void OpenVariant()
    {
        _variantEditId = null;
        _variant = new VariantForm { Sku = GenerateSku(product?.Name), Barcode = GenerateBarcode() };
        _variant.Attributes.Add(new ProductAttribute());
        _variantError = null;
        _showVariant = true;
    }

    /// <summary>Génère un code-barres EAN-13 valide (12 chiffres aléatoires + clé de contrôle).</summary>
    private static string GenerateBarcode()
    {
        var rng = Random.Shared;
        var digits = new int[13];
        for (var i = 0; i < 12; i++) digits[i] = rng.Next(0, 10);

        var sum = 0;
        for (var i = 0; i < 12; i++) sum += digits[i] * (i % 2 == 0 ? 1 : 3);
        digits[12] = (10 - (sum % 10)) % 10;

        return string.Concat(digits);
    }

    private void OpenEditVariant(ProductVariant v)
    {
        _variantEditId = v.Id;
        _variant = new VariantForm
        {
            Sku = v.Sku,
            Barcode = v.Barcode ?? "",
            WeightGrams = v.WeightGrams,
            Attributes = v.Attributes.Select(a => new ProductAttribute { Key = a.Key, Value = a.Value }).ToList()
        };
        if (_variant.Attributes.Count == 0) _variant.Attributes.Add(new ProductAttribute());
        _variantError = null;
        _showVariant = true;
    }

    private async Task SaveVariant()
    {
        if (product is null) return;
        if (string.IsNullOrWhiteSpace(_variant.Sku)) { _variantError = "Le SKU de la variante est requis."; return; }

        var attrs = _variant.Attributes
            .Where(a => !string.IsNullOrWhiteSpace(a.Key))
            .GroupBy(a => a.Key.Trim())
            .ToDictionary(g => g.Key, g => g.Last().Value?.Trim() ?? "");

        var request = new VariantRequest(
            _variant.Sku.Trim(),
            attrs.Count > 0 ? attrs : null,
            string.IsNullOrWhiteSpace(_variant.Barcode) ? null : _variant.Barcode.Trim(),
            _variant.WeightGrams,
            _variant.LengthMm > 0 ? _variant.LengthMm : null,
            _variant.WidthMm > 0 ? _variant.WidthMm : null,
            _variant.HeightMm > 0 ? _variant.HeightMm : null);

        try
        {
            if (_variantEditId is { } vid)
            {
                await Api.UpdateVariantAsync(product.Id, vid, request);
            }
            else
            {
                await Api.AddVariantAsync(product.Id, request);
            }
            _showVariant = false;
            await ReloadProduct();
        }
        catch (Exception ex) { _variantError = ex.Message; }
    }

    private async Task RemoveVariant(Guid variantId)
    {
        if (product is null) return;
        try { await Api.RemoveVariantAsync(product.Id, variantId); await ReloadProduct(); }
        catch (Exception ex) { _variantError = ex.Message; }
    }

    private async Task ChangeStatus(string status)
    {
        if (product is null) return;
        _statusError = null;
        try { await Api.SetProductStatusAsync(product.Id, new CatalogStatusRequest(status)); await ReloadProduct(); }
        catch (Exception ex) { _statusError = $"Changement de statut impossible : {ex.Message}"; }
    }

    private async Task FlagReview(Guid reviewId)
    {
        try { await Api.FlagAsync(reviewId); await LoadReviews(); }
        catch { /* ignore */ }
    }

    private async Task DeleteProduct()
    {
        if (product is null) return;
        await Api.DeleteProductAsync(product.Id);
        Nav.NavigateTo("produits");
    }

    // ---------- Édition ----------
    private async Task OpenEdit()
    {
        if (product is null) return;
        _editError = null;
        _edit = new EditForm
        {
            Name = product.Name,
            Description = product.Description ?? "",
            Gtin = product.Gtin ?? "",
            Ean = product.Ean ?? "",
            TagsText = string.Join(", ", product.Tags),
            ProductGroupIdText = product.ProductGroupId?.ToString() ?? "",
            Attributes = product.Attributes.Select(a => new ProductAttribute { Key = a.Key, Value = a.Value }).ToList()
        };
        _showEdit = true;
        if (_brands is null)
        {
            try { _brands = await Api.ListBrandsAsync(); } catch { _brands = Array.Empty<SellerBrand>(); }
        }
    }

    private async Task SaveEdit()
    {
        if (product is null) return;
        if (string.IsNullOrWhiteSpace(_edit.Name)) { _editError = "Le nom est requis."; return; }

        var tags = _edit.TagsText.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToList();
        Guid? brandId = Guid.TryParse(_edit.BrandId, out var b) ? b : null;

        Guid? productGroupId = null;
        if (!string.IsNullOrWhiteSpace(_edit.ProductGroupIdText))
        {
            if (!Guid.TryParse(_edit.ProductGroupIdText.Trim(), out var pgid)) { _editError = "Le groupe de produit doit être un GUID valide."; return; }
            productGroupId = pgid;
        }

        var attrs = _edit.Attributes
            .Where(a => !string.IsNullOrWhiteSpace(a.Key))
            .GroupBy(a => a.Key.Trim())
            .ToDictionary(g => g.Key, g => g.Last().Value?.Trim() ?? "");

        try
        {
            await Api.UpdateProductAsync(product.Id, new UpdateProductRequest(
                _edit.Name.Trim(),
                string.IsNullOrWhiteSpace(_edit.Description) ? null : _edit.Description.Trim(),
                BrandId: brandId,
                Gtin: string.IsNullOrWhiteSpace(_edit.Gtin) ? null : _edit.Gtin.Trim(),
                Ean: string.IsNullOrWhiteSpace(_edit.Ean) ? null : _edit.Ean.Trim(),
                ProductGroupId: productGroupId,
                Attributes: attrs.Count > 0 ? attrs : null,
                Tags: tags.Count > 0 ? tags : null));
            _showEdit = false;
            product = await Api.GetProductDetailAsync(Id);
        }
        catch (Exception ex) { _editError = ex.Message; }
    }

    // ---------- Ajout d'offre ----------
    private async Task OpenOffer()
    {
        _offerError = null;
        _offer = new OfferForm { Sku = GenerateSku(product?.Name) };
        _showOffer = true;
        if (_locations is null)
        {
            try { _locations = await Api.ListLocationsAsync(); } catch { _locations = Array.Empty<Location>(); }
        }
    }

    private void RegenerateSku() => _offer.Sku = GenerateSku(product?.Name);

    /// <summary>SKU auto : préfixe alphanumérique du nom (max 6) + suffixe aléatoire de 4.</summary>
    private static string GenerateSku(string? name)
    {
        var prefix = new string((name ?? "PRD")
            .ToUpperInvariant()
            .Where(char.IsLetterOrDigit)
            .Take(6)
            .ToArray());
        if (prefix.Length == 0) prefix = "PRD";

        const string alphabet = "ABCDEFGHJKLMNPQRSTUVWXYZ23456789";
        var rng = Random.Shared;
        var suffix = new string(Enumerable.Range(0, 4).Select(_ => alphabet[rng.Next(alphabet.Length)]).ToArray());
        return $"{prefix}-{suffix}";
    }

    private async Task CreateOffer()
    {
        if (product is null) return;
        if (string.IsNullOrWhiteSpace(_offer.Sku)) { _offerError = "Le SKU est requis."; return; }
        if (_offer.Price <= 0) { _offerError = "Le prix doit être positif."; return; }
        if (!Guid.TryParse(_offer.LocationId, out var locId)) { _offerError = "Choisissez un lieu d'expédition."; return; }

        try
        {
            await Api.CreateOfferAsync(new CreateOfferRequest(
                ProductId: product.Id,
                Sku: _offer.Sku.Trim(),
                BasePriceAmount: _offer.Price,
                Currency: _offer.Currency,
                Condition: _offer.Condition,
                FulfillmentType: "Fbs",   // Fulfilled by Seller (le vendeur expédie)
                ShipFromLocationId: locId,
                HandlingTime: _offer.HandlingTime));
            _showOffer = false;
            await ReloadOffers();
        }
        catch (Exception ex) { _offerError = ex.Message; }
    }

