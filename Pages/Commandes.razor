@page "/commandes"
@using Seller_MP_Dashboard.Api
@inject ISellerApi Api
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Commandes — Espace Vendeur</PageTitle>

<PageHeader Title="Commandes"
            Subtitle="@(orders is null ? "Chargement…" : $"{orders.Count} commandes · {ToProcess} à traiter")">
    <Actions>
        <MpButton Variant="ButtonVariant.Secondary" Icon="download" Disabled="@(Filtered.Count == 0)" OnClick="ExportCsv">Exporter</MpButton>
    </Actions>
</PageHeader>

@if (loadError is not null)
{
    <ErrorNotice Title="Commandes indisponibles" Message="@loadError" OnRetry="Reload" />
}
else if (orders is null)
{
    <p class="mp-caption">Chargement…</p>
}
else
{
    <div class="cmd-toolbar">
        <input class="mp-input cmd-search" placeholder="Rechercher une référence ou un client…"
               @bind="search" @bind:event="oninput" />
        <div class="cmd-filters">
            @foreach (var f in _filters)
            {
                <button type="button" class="cmd-chip @(statusFilter == f.Key ? "active" : "")"
                        @onclick="() => SetFilter(f.Key)">@f.Label</button>
            }
        </div>
        <span class="mp-caption cmd-count">@Filtered.Count commande@(Filtered.Count > 1 ? "s" : "")</span>
    </div>

    @if (Filtered.Count == 0)
    {
        <div class="cmd-empty">
            <div class="cmd-empty-ico"><AppIcon Name="shopping-cart" Size="40" StrokeWidth="1.5" /></div>
            <p class="mp-body-strong">Aucune commande</p>
            <p class="mp-caption">Aucune commande ne correspond à votre recherche.</p>
        </div>
    }
    else
    {
    <MpCard NoPadding="true">
        <ChildContent>
            <table class="mp-table">
                <thead>
                    <tr>
                        <th>Référence</th>
                        <th>Client</th>
                        <th>Date</th>
                        <th class="num">Articles</th>
                        <th class="num">Montant</th>
                        <th>Paiement</th>
                        <th>Statut</th>
                        <th class="actions-col">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var o in Paged)
                    {
                        <tr>
                            <td><a class="mp-num order-ref" href="commande/@o.Id">@o.Reference</a></td>
                            <td class="cust-name">@o.Customer</td>
                            <td class="mp-num">@Format.Date(o.Date)</td>
                            <td class="num mp-num">@o.ItemCount</td>
                            <td class="num mp-num mp-body-strong">@Format.Xof(o.TotalXof)</td>
                            <td><OrderStatusBadge Payment="o.UiPayment" ShowPayment="true" /></td>
                            <td><OrderStatusBadge Status="o.UiStatus" /></td>
                            <td class="actions-col">
                                @* Une commande non payée n'est pas traitable : on n'expose « Traiter »
                                   que si le paiement est confirmé ET la commande à traiter. *@
                                @if (o.UiPayment == PaymentStatus.Paid && o.UiStatus is OrderStatus.Pending or OrderStatus.Processing)
                                {
                                    <MpButton Variant="ButtonVariant.Primary" OnClick="@(() => Nav.NavigateTo($"commande/{o.Id}"))">Traiter</MpButton>
                                }
                                else
                                {
                                    <MpButton Variant="ButtonVariant.Tertiary" OnClick="@(() => Nav.NavigateTo($"commande/{o.Id}"))">Détails</MpButton>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </ChildContent>
    </MpCard>

    @if (PageCount > 1)
    {
        <div class="cmd-pager">
            <button class="cmd-page-btn" type="button" disabled="@(_page <= 1)" @onclick="Prev">Précédent</button>
            <span class="mp-caption">Page @_page / @PageCount</span>
            <button class="cmd-page-btn" type="button" disabled="@(_page >= PageCount)" @onclick="Next">Suivant</button>
        </div>
    }
    }
}

<style>
    .cust-name { font-weight: 500; }
    .cmd-toolbar { display: flex; align-items: center; gap: var(--mp-space-4); flex-wrap: wrap; margin-bottom: var(--mp-space-4); }
    .cmd-search { flex: 1 1 260px; max-width: 380px; }
    .cmd-filters { display: flex; gap: var(--mp-space-2); flex-wrap: wrap; }
    .cmd-chip { border: 0.5px solid var(--mp-border); background-color: var(--mp-surface); border-radius: 999px; padding: 5px 14px; font-size: 13px; cursor: pointer; color: var(--mp-text); transition: all .15s ease; }
    .cmd-chip:hover { border-color: var(--mp-primary); color: var(--mp-primary); }
    .cmd-chip.active { background-color: var(--mp-primary); border-color: var(--mp-primary); color: #fff; }
    .cmd-count { margin-left: auto; }
    .cmd-empty { text-align: center; padding: var(--mp-space-8) var(--mp-space-4); border: 1px dashed var(--mp-border); border-radius: var(--mp-radius-lg); display: flex; flex-direction: column; gap: var(--mp-space-2); align-items: center; }
    .cmd-pager { display: flex; align-items: center; justify-content: center; gap: var(--mp-space-4); margin-top: var(--mp-space-4); }
    .cmd-page-btn { border: 0.5px solid var(--mp-border); background: var(--mp-surface); border-radius: var(--mp-radius-md); padding: 6px 16px; font-size: 13px; cursor: pointer; color: var(--mp-text); }
    .cmd-page-btn:hover:not(:disabled) { border-color: var(--mp-primary); color: var(--mp-primary); }
    .cmd-page-btn:disabled { opacity: .5; cursor: default; }
</style>

@code {
    private IReadOnlyList<SellerOrder>? orders;
    private string? loadError;
    private string search = "";
    private string statusFilter = "all";
    private int _page = 1;
    private const int PageSize = 15;

    private readonly (string Key, string Label)[] _filters =
    {
        ("all", "Toutes"),
        ("todo", "À traiter"),
        ("shipped", "Expédiées"),
        ("delivered", "Livrées"),
        ("cancelled", "Annulées"),
    };

    protected override Task OnInitializedAsync() => Reload();

    private async Task Reload()
    {
        loadError = null;
        orders = null;
        _page = 1;
        try { orders = await Api.ListOrdersAsync(); }
        catch (Exception ex) { loadError = ex.Message; }
    }

    private int ToProcess => orders?.Count(o => o.UiStatus is OrderStatus.Pending or OrderStatus.Processing) ?? 0;

    private void SetFilter(string key) { statusFilter = key; _page = 1; }

    private List<SellerOrder> Filtered
    {
        get
        {
            if (orders is null) return new();
            IEnumerable<SellerOrder> q = orders;

            q = statusFilter switch
            {
                "todo" => q.Where(o => o.UiStatus is OrderStatus.Pending or OrderStatus.Processing),
                "shipped" => q.Where(o => o.UiStatus == OrderStatus.Shipped),
                "delivered" => q.Where(o => o.UiStatus == OrderStatus.Delivered),
                "cancelled" => q.Where(o => o.UiStatus == OrderStatus.Cancelled),
                _ => q,
            };

            if (!string.IsNullOrWhiteSpace(search))
            {
                var s = search.Trim();
                q = q.Where(o => (o.Reference ?? "").Contains(s, StringComparison.OrdinalIgnoreCase)
                              || (o.Customer ?? "").Contains(s, StringComparison.OrdinalIgnoreCase));
            }
            return q.ToList();
        }
    }

    private int PageCount => Math.Max(1, (int)Math.Ceiling(Filtered.Count / (double)PageSize));
    private IEnumerable<SellerOrder> Paged => Filtered.Skip((Math.Min(_page, PageCount) - 1) * PageSize).Take(PageSize);

    private void Prev() { if (_page > 1) _page--; }
    private void Next() { if (_page < PageCount) _page++; }

    private async Task ExportCsv()
    {
        var rows = Filtered;
        if (rows.Count == 0) return;

        var sb = new System.Text.StringBuilder();
        sb.AppendLine("Référence;Client;Date;Articles;Montant XOF;Paiement;Statut");
        foreach (var o in rows)
        {
            sb.Append(Csv(o.Reference)).Append(';')
              .Append(Csv(o.Customer)).Append(';')
              .Append(Csv(o.Date.ToString("yyyy-MM-dd"))).Append(';')
              .Append(o.ItemCount).Append(';')
              .Append(o.TotalXof).Append(';')
              .Append(Csv(o.UiPayment.ToString())).Append(';')
              .Append(Csv(o.UiStatus.ToString())).AppendLine();
        }

        var name = $"commandes_{DateTime.Now:yyyyMMdd}.csv";
        await JS.InvokeVoidAsync("hbaDownload", name, sb.ToString(), "text/csv");
    }

    private static string Csv(string? value)
    {
        var v = value ?? "";
        if (v.Contains('"') || v.Contains(';') || v.Contains('\n') || v.Contains('\r'))
            v = "\"" + v.Replace("\"", "\"\"") + "\"";
        return v;
    }
}
