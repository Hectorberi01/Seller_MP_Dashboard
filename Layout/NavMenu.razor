@inject AuthState Auth
@inject NavigationManager Nav

@* Icônes SVG line (Lucide), couleur héritée via currentColor. *@

<div class="sb-top navbar">
    <a class="sb-brand" href="">
        <span class="sb-logo" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="#fff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/>
            </svg>
        </span>
        <span class="sb-brand-text">
            <span class="sb-brand-name">HbaExpress</span>
            <span class="sb-brand-pro">Pro</span>
        </span>
    </a>
    <button title="Menu" class="navbar-toggler" @onclick="ToggleNavMenu">
        <span class="navbar-toggler-icon"></span>
    </button>
</div>

<div class="@NavMenuCssClass sb-body" @onclick="ToggleNavMenu">
    <nav class="sb-nav">
        <div class="nav-item">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="nav-ico" aria-hidden="true">
                    <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="9" rx="1"/><rect x="14" y="3" width="7" height="5" rx="1"/><rect x="14" y="12" width="7" height="9" rx="1"/><rect x="3" y="16" width="7" height="5" rx="1"/></svg>
                </span>
                <span class="nav-txt">Tableau de bord</span>
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="commandes">
                <span class="nav-ico" aria-hidden="true">
                    <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="8" y="2" width="8" height="4" rx="1"/><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><path d="M9 12h6M9 16h6"/></svg>
                </span>
                <span class="nav-txt">Commandes</span>
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="produits">
                <span class="nav-ico" aria-hidden="true">
                    <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></svg>
                </span>
                <span class="nav-txt">Produits</span>
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="apercu-catalogue">
                <span class="nav-ico" aria-hidden="true">
                    <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/></svg>
                </span>
                <span class="nav-txt">Aperçu catalogue</span>
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="finances">
                <span class="nav-ico" aria-hidden="true">
                    <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="M18 17V9"/><path d="M13 17V5"/><path d="M8 17v-3"/></svg>
                </span>
                <span class="nav-txt">Finances</span>
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="portefeuille">
                <span class="nav-ico" aria-hidden="true">
                    <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M19 7V5a2 2 0 0 0-2-2H5a2 2 0 0 0 0 4h16a1 1 0 0 1 1 1v3"/><path d="M3 5v14a2 2 0 0 0 2 2h15a1 1 0 0 0 1-1v-3"/><path d="M18 12a2 2 0 0 0 0 4h4v-4Z"/></svg>
                </span>
                <span class="nav-txt">Portefeuille</span>
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="messagerie">
                <span class="nav-ico" aria-hidden="true">
                    <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/></svg>
                </span>
                <span class="nav-txt">Messagerie</span>
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="avis">
                <span class="nav-ico" aria-hidden="true">
                    <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.1 8.3 22 9.3 17 14.1 18.2 21 12 17.8 5.8 21 7 14.1 2 9.3 8.9 8.3 12 2"/></svg>
                </span>
                <span class="nav-txt">Avis</span>
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="expeditions">
                <span class="nav-ico" aria-hidden="true">
                    <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 18V6a1 1 0 0 0-1-1H3a1 1 0 0 0-1 1v11a1 1 0 0 0 1 1h1"/><path d="M14 9h4l4 4v4a1 1 0 0 1-1 1h-1"/><circle cx="7" cy="18" r="2"/><circle cx="17" cy="18" r="2"/><path d="M9 18h6"/></svg>
                </span>
                <span class="nav-txt">Expéditions</span>
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="boutique">
                <span class="nav-ico" aria-hidden="true">
                    <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="m2 7 2-4h16l2 4"/><path d="M4 7v13a1 1 0 0 0 1 1h14a1 1 0 0 0 1-1V7"/><path d="M2 7h20"/><path d="M9 21v-6h6v6"/></svg>
                </span>
                <span class="nav-txt">Ma boutique</span>
            </NavLink>
        </div>
    </nav>

    <div class="sb-profile">
        <div class="sb-avatar" aria-hidden="true">@Initials</div>
        <div class="sb-profile-meta">
            <span class="sb-profile-name">@SellerName</span>
            <span class="sb-profile-role">Vendeur</span>
        </div>
        <button class="sb-logout" title="Se déconnecter" @onclick="Logout">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
        </button>
    </div>
</div>

@code {
    private bool collapseNavMenu = true;
    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;
    private void ToggleNavMenu() => collapseNavMenu = !collapseNavMenu;

    private string SellerName => string.IsNullOrEmpty(Auth.SellerName) ? "Ma boutique" : Auth.SellerName!;

    private string Initials
    {
        get
        {
            var parts = SellerName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
            if (parts.Length == 0) return "?";
            var first = parts[0].Length > 0 ? parts[0][0].ToString() : "";
            var second = parts.Length > 1 && parts[1].Length > 0 ? parts[1][0].ToString() : "";
            return (first + second).ToUpperInvariant();
        }
    }

    private async Task Logout()
    {
        await Auth.ClearAsync();
        Nav.NavigateTo("login");
    }
}
